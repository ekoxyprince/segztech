<!-- Page Header -->
<div class="page-header">
  <div>
    <h2>User Details</h2>
    <p class="text-muted"><%= user.firstName %> <%= user.lastName %></p>
  </div>
  <div class="page-actions">
    <a href="/admin/users" class="btn btn-outline">
      <i class="fas fa-arrow-left"></i> Back to Users
    </a>
  </div>
</div>

<!-- User Info Cards -->
<div class="user-info-grid">
  <div class="info-card profile-card">
    <div class="profile-header">
      <img src="<%= user.avatar %>" alt="<%= user.firstName %>" class="profile-avatar">
      <div class="profile-details">
        <h3><%= user.firstName %> <%= user.lastName %></h3>
        <p><i class="fas fa-envelope"></i> <%= user.email %></p>
        <p><i class="fas fa-phone"></i> <%= user.phone || 'Not provided' %></p>
        <span class="role-badge <%= user.role %>"><%= user.role %></span>
      </div>
    </div>
  </div>
  
  <div class="info-card">
    <div class="info-header">
      <i class="fas fa-chart-line"></i>
      <h4>User Statistics</h4>
    </div>
    <div class="info-content stats-grid">
      <div class="stat-item">
        <span class="stat-number"><%= orders.length %></span>
        <span class="stat-label">Total Orders</span>
      </div>
      <div class="stat-item">
        <span class="stat-number"><%= orders.filter(o => o.status === 'delivered').length %></span>
        <span class="stat-label">Delivered</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">₦<%= orders.reduce((sum, o) => sum + o.total, 0).toFixed(2) %></span>
        <span class="stat-label">Total Spent</span>
      </div>
    </div>
  </div>
  
  <div class="info-card">
    <div class="info-header">
      <i class="fas fa-calendar-alt"></i>
      <h4>Account Info</h4>
    </div>
    <div class="info-content">
      <p><strong>Member Since:</strong> <%= new Date(user.createdAt).toLocaleDateString() %></p>
      <p><strong>User ID:</strong> <%= user.id %></p>
      <p><strong>Status:</strong> <span class="status-badge <%= user.status === 'active' ? 'status-delivered' : 'status-cancelled' %>"><%= user.status || 'active' %></span></p>
    </div>
  </div>
</div>

<!-- User Addresses -->
<% if (user.addresses && user.addresses.length > 0) { %>
<div class="addresses-section">
  <h3><i class="fas fa-map-marker-alt"></i> Saved Addresses</h3>
  <div class="addresses-grid">
    <% user.addresses.forEach(address => { %>
      <div class="address-card <%= address.isDefault ? 'default' : '' %>">
        <span class="address-label"><%= address.label %></span>
        <% if (address.isDefault) { %>
          <span class="default-badge">Default</span>
        <% } %>
        <p><%= address.fullName %></p>
        <p><%= address.street %></p>
        <p><%= address.city %>, <%= address.state %> <%= address.zipCode %></p>
        <p><%= address.country %></p>
        <p><i class="fas fa-phone"></i> <%= address.phone %></p>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- User Orders -->
<div class="table-card">
  <div class="card-header">
    <h3><i class="fas fa-shopping-bag"></i> Order History</h3>
  </div>
  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Items</th>
          <th>Total</th>
          <th>Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr>
              <td>
                <span class="order-id">#<%= order.orderNumber %></span>
              </td>
              <td><%= order.items.length %> item(s)</td>
              <td><strong>₦<%= order.total.toFixed(2) %></strong></td>
              <td>
                <span class="status-badge status-<%= order.status %>">
                  <%= order.status %>
                </span>
              </td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td>
                <a href="/admin/orders/<%= order.id %>" class="btn-icon" title="View">
                  <i class="fas fa-eye"></i>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="no-data">No orders found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<style>
.user-info-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 24px;
  margin-bottom: 30px;
}

.info-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border);
}

.profile-card {
  display: flex;
  flex-direction: column;
}

.profile-header {
  display: flex;
  gap: 20px;
  align-items: center;
}

.profile-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid var(--primary);
}

.profile-details h3 {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 8px;
}

.profile-details p {
  color: var(--text-secondary);
  font-size: 14px;
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.profile-details p i {
  color: var(--text-muted);
  width: 16px;
}

.role-badge {
  display: inline-block;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  margin-top: 12px;
}

.role-badge.admin {
  background: rgba(255, 106, 0, 0.2);
  color: var(--primary);
}

.role-badge.user {
  background: rgba(9, 132, 227, 0.2);
  color: var(--info);
}

.info-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.info-header i {
  font-size: 20px;
  color: var(--primary);
}

.info-header h4 {
  font-size: 16px;
  font-weight: 700;
}

.info-content p {
  margin-bottom: 8px;
  font-size: 14px;
  color: var(--text-secondary);
}

.info-content strong {
  color: var(--text-primary);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.stat-number {
  font-size: 24px;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: 12px;
  color: var(--text-muted);
}

.addresses-section {
  margin-bottom: 30px;
}

.addresses-section h3 {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.addresses-section h3 i {
  color: var(--primary);
}

.addresses-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

.address-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 20px;
  border: 1px solid var(--border);
  position: relative;
}

.address-card.default {
  border-color: var(--primary);
  background: var(--primary-light);
}

.address-label {
  font-weight: 700;
  font-size: 14px;
  color: var(--text-primary);
}

.default-badge {
  position: absolute;
  top: 16px;
  right: 16px;
  background: var(--primary);
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 10px;
}

.address-card p {
  font-size: 14px;
  color: var(--text-secondary);
  margin: 4px 0;
}

.address-card p i {
  width: 16px;
  color: var(--text-muted);
}

.order-id {
  font-weight: 600;
  color: var(--primary);
}

.text-muted {
  color: var(--text-muted);
  font-size: 14px;
  margin-top: 4px;
}

@media (max-width: 992px) {
  .user-info-grid {
    grid-template-columns: 1fr;
  }
  
  .profile-header {
    flex-direction: column;
    text-align: center;
  }
}
</style>
