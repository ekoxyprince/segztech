<!-- Page Header -->
<div class="page-header">
  <div>
    <h2>Products</h2>
    <p class="page-subtitle">Manage your product inventory</p>
  </div>
  <button class="btn btn-primary" id="addProductBtn">
    <i class="fas fa-plus"></i> Add Product
  </button>
</div>

<!-- Filters -->
<div class="filters-bar">
  <div class="filter-group">
    <label>Category</label>
    <select class="filter-select" id="categoryFilter">
      <option value="">All Categories</option>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.slug %>"><%= cat.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="filter-group">
    <label>Brand</label>
    <select class="filter-select" id="brandFilter" disabled>
      <option value="">All Brands</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Model</label>
    <select class="filter-select" id="modelFilter" disabled>
      <option value="">All Models</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Series</label>
    <select class="filter-select" id="seriesFilter" disabled>
      <option value="">All Series</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Stock</label>
    <select class="filter-select" id="stockFilter">
      <option value="">All Stock</option>
      <option value="in-stock">In Stock</option>
      <option value="low-stock">Low Stock</option>
      <option value="out-of-stock">Out of Stock</option>
    </select>
  </div>
  <div class="filter-divider"></div>
  <div class="filter-search">
    <i class="fas fa-search"></i>
    <input type="text" id="searchInput" placeholder="Search products...">
  </div>
  <div class="filter-results" id="filterResults">
    <strong><%= products ? products.length : 0 %></strong> products found
  </div>
</div>

<!-- Products Table -->
<div class="table-card">
  <div id="loadingState" class="loading-state" style="display: none;">
    <div class="spinner"></div>
    <span>Loading products...</span>
  </div>
  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Category</th>
          <th>Price</th>
          <th>Stock</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="productsTableBody">
        <% if (products && products.length > 0) { %>
          <% products.forEach(function(product) { %>
            <tr data-id="<%= product.id %>">
              <td>
                <div class="product-cell">
                  <img src="<%= product.images && product.images[0] ? product.images[0].image_url : '/images/placeholder.jpg' %>" alt="<%= product.name %>" class="product-thumb">
                  <div class="product-info">
                    <span class="product-name"><%= product.name %></span>
                  </div>
                </div>
              </td>
              <td><span class="category-tag"><%= product.category || 'Uncategorized' %></span></td>
              <td>
                <div class="price-cell">
                  <span class="current-price">₦<%= product.price.toFixed(2) %></span>
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="original-price">₦<%= product.originalPrice.toFixed(2) %></span>
                    <span class="discount-badge">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%</span>
                  <% } %>
                </div>
              </td>
              <td><span class="stock-count <%= product.stock === 0 ? 'out-of-stock' : (product.stock < 10 ? 'low-stock' : 'in-stock') %>"><%= product.stock %></span></td>
              <td>
                <span class="status-badge <%= product.stock === 0 ? 'status-cancelled' : (product.stock < 10 ? 'status-pending' : 'status-delivered') %>">
                  <%= product.stock === 0 ? 'Out of Stock' : (product.stock < 10 ? 'Low Stock' : 'In Stock') %>
                </span>
              </td>
              <td>
                <div class="action-buttons">
                  <button class="btn-icon view-btn" data-id="<%= product.id %>" title="View">
                    <i class="fas fa-eye"></i>
                  </button>
                  <button class="btn-icon edit-btn" data-id="<%= product.id %>" title="Edit">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button class="btn-icon btn-delete delete-btn" data-id="<%= product.id %>" title="Delete">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6">
              <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <p>No products found</p>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- View Product Modal -->
<div class="modal-overlay" id="viewModal">
  <div class="modal modal-xl">
    <div class="modal-header">
      <h3><i class="fas fa-eye"></i> Product Details</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body" id="viewModalBody">
      <div class="loading-state">
        <div class="spinner"></div>
        <span>Loading...</span>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Close</button>
      <button type="button" class="btn btn-primary" id="viewEditBtn">
        <i class="fas fa-edit"></i> Edit Product
      </button>
    </div>
  </div>
</div>

<!-- Product Form Modal -->
<div class="modal-overlay" id="productModal">
  <div class="modal modal-xl">
    <div class="modal-header">
      <h3 id="productModalTitle"><i class="fas fa-plus"></i> Add Product</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="productForm" enctype="multipart/form-data">
      <div class="modal-body">
        <input type="hidden" id="productId" name="id">
        
        <!-- Cascade Progress -->
        <div class="cascade-progress" id="cascadeProgress">
          <span class="cascade-step active" id="step-category">Category</span>
          <span class="cascade-arrow">&#8594;</span>
          <span class="cascade-step" id="step-type">Type</span>
          <span class="cascade-arrow">&#8594;</span>
          <span class="cascade-step" id="step-brand">Brand</span>
          <span class="cascade-arrow">&#8594;</span>
          <span class="cascade-step" id="step-model">Model</span>
          <span class="cascade-arrow">&#8594;</span>
          <span class="cascade-step" id="step-series">Series</span>
        </div>
        
        <div class="form-grid">
          <div class="form-section">
            <h4><i class="fas fa-sitemap"></i> Product Hierarchy</h4>
            
            <div class="form-group">
              <label for="productCategory">Category *</label>
              <select class="form-control" id="productCategory" name="category" required onchange="modalOnCategoryChange()">
                <option value="">-- Select Category --</option>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat.slug %>" data-hastypes="<%= hierarchy && hierarchy.getTypes && hierarchy.getTypes(cat.slug).length > 0 ? 'true' : 'false' %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
            
            <div class="form-group" id="modalTypeGroup" style="display:none;">
              <label for="productType">Product Type *</label>
              <select class="form-control" id="productType" name="subcategory" onchange="modalOnTypeChange()">
                <option value="">-- Select Type --</option>
              </select>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="productBrand">Brand *</label>
                <select class="form-control" id="productBrand" name="brand" required disabled onchange="modalOnBrandChange()">
                  <option value="">-- Select Brand --</option>
                </select>
              </div>
              <div class="form-group">
                <label for="productModel">Model Line *</label>
                <select class="form-control" id="productModel" name="model" required disabled onchange="modalOnModelChange()">
                  <option value="">-- Select Model --</option>
                </select>
              </div>
            </div>
            
            <div class="form-group">
              <label for="productSeries">Specific Series/Variant *</label>
              <select class="form-control" id="productSeries" name="series" required disabled>
                <option value="">-- Select Series --</option>
              </select>
            </div>
          </div>
          
          <div class="form-section">
            <h4><i class="fas fa-info-circle"></i> Basic Info</h4>
            
            <div class="form-group">
              <label for="productName">Product Name *</label>
              <input type="text" class="form-control" id="productName" name="name" required placeholder="e.g., HP EliteBook 840 G10 Core i7 16GB">
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="productCondition">Condition *</label>
                <select class="form-control" id="productCondition" name="condition">
                  <option value="new">New</option>
                  <option value="used_like_new">Used - Like New</option>
                  <option value="used_good">Used - Good</option>
                  <option value="used_fair">Used - Fair</option>
                  <option value="refurbished">Refurbished</option>
                </select>
              </div>
              <div class="form-group">
                <label for="productSku">SKU</label>
                <input type="text" class="form-control" id="productSku" name="sku" placeholder="Auto-generated if empty">
              </div>
            </div>
            
            <div class="form-group">
              <label for="productShortDesc">Short Description</label>
              <input type="text" class="form-control" id="productShortDesc" name="shortDescription" maxlength="200">
            </div>
            
            <div class="form-group">
              <label for="productDesc">Full Description *</label>
              <textarea class="form-control" id="productDesc" name="description" rows="4" required></textarea>
            </div>
          </div>
          
          <div class="form-section">
            <h4><i class="fas fa-dollar-sign"></i> Pricing & Stock</h4>
            
            <div class="form-row">
              <div class="form-group">
                <label for="productPrice">Price ($) *</label>
                <input type="number" class="form-control" id="productPrice" name="price" step="0.01" min="0" required>
              </div>
              <div class="form-group">
                <label for="productOriginalPrice">Original Price ($)</label>
                <input type="number" class="form-control" id="productOriginalPrice" name="originalPrice" step="0.01" min="0">
              </div>
            </div>
            
            <div class="form-group">
              <label for="productStock">Stock Quantity *</label>
              <input type="number" class="form-control" id="productStock" name="stock" min="0" required>
            </div>
            
            <div class="form-group">
              <label>Product Tags</label>
              <div class="checkbox-group">
                <label class="checkbox-label"><input type="checkbox" id="productFeatured" name="isFeatured"><span>Featured</span></label>
                <label class="checkbox-label"><input type="checkbox" id="productFlashSale" name="isFlashSale"><span>Flash Sale</span></label>
                <label class="checkbox-label"><input type="checkbox" id="productHotPick" name="isHotPick"><span>Hot Pick</span></label>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Dynamic Specs -->
        <div class="form-section full-width" id="modalSpecsSection" style="display:none;">
          <h4><i class="fas fa-microchip"></i> Technical Specifications <small id="modalSpecsInfo" style="color:var(--text-muted);font-weight:normal;"></small></h4>
          <div class="specs-grid" id="specsGrid"></div>
        </div>
        
        <!-- Images -->
        <div class="form-section full-width">
          <h4><i class="fas fa-image"></i> Images</h4>
          <div class="upload-area" id="modalImageUploadArea">
            <input type="file" id="productImages" name="newImages" multiple accept="image/*" onchange="modalPreviewImages(event)">
            <div class="upload-placeholder">
              <i class="fas fa-cloud-upload-alt"></i>
              <p>Click or drag images here to upload</p>
              <span>JPG, PNG, WebP (Max 5MB each)</span>
            </div>
            <div class="image-preview-grid" id="modalImagePreviewGrid"></div>
          </div>
        </div>

        <!-- Video -->
        <div class="form-section full-width">
          <h4><i class="fas fa-video"></i> Product Video</h4>
          <div class="upload-area">
            <input type="file" id="productVideo" name="video" accept="video/*">
            <div class="upload-placeholder">
              <i class="fas fa-video"></i>
              <p>Upload product video (optional)</p>
              <span>MP4, WebM (Max 50MB)</span>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline close-modal">Cancel</button>
        <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
          <i class="fas fa-spinner fa-spin" style="display: none;"></i>
          <span>Save Product</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h3><i class="fas fa-trash"></i> Delete Product</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to delete this product? This action cannot be undone.</p>
      <input type="hidden" id="deleteProductId">
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Cancel</button>
      <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
        <i class="fas fa-spinner fa-spin" style="display: none;"></i>
        <span>Delete</span>
      </button>
    </div>
  </div>
</div>

<style>
.cascade-progress {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 20px;
  padding: 12px 16px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  font-size: 13px;
  flex-wrap: wrap;
}
.cascade-step {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 20px;
  background: var(--border);
  color: var(--text-muted);
  transition: all 0.3s;
  font-weight: 500;
}
.cascade-step.active {
  background: var(--primary);
  color: white;
}
.cascade-step.completed {
  background: #10b981;
  color: white;
}
.cascade-arrow {
  color: var(--text-muted);
  font-size: 11px;
}
.specs-grid .form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 768px) {
  .specs-grid .form-row { grid-template-columns: 1fr; }
}
.detail-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin: 20px 0;
  padding: 16px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
}
.detail-row {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.detail-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--text-muted);
  letter-spacing: 0.5px;
}
.detail-row span:last-child {
  font-size: 14px;
  color: var(--text-primary);
  font-weight: 500;
}
.detail-description {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}
.detail-description h4 {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 10px;
  color: var(--text-primary);
}
.detail-description p {
  font-size: 14px;
  line-height: 1.7;
  color: var(--text-secondary);
  white-space: pre-wrap;
}
</style>

<script>
$(document).ready(function() {
  try {
    var allProducts = [];
    var currentViewId = null;
    var isEditMode = false;
    var uploadedImages = [];
    var uploadedVideo = null;
    var categorySpecs = {};
    var modalCurrentCategory = '';
    var modalCurrentType = '';
    var modalCurrentBrand = '';
    var modalCurrentModel = '';
    var modalCurrentSeries = '';

    loadProducts();
    loadCategorySpecs();
    initEventHandlers();
    console.log('Products page initialized successfully');

  window.changeMainImage = function(src) {
    var mainImg = document.getElementById('viewMainImage');
    if (mainImg) mainImg.src = src;
  };

  window.modalPreviewImages = function(event) {
    var files = event.target.files;
    var previewGrid = document.getElementById('modalImagePreviewGrid');
    if (!previewGrid) return;
    Array.from(files).forEach(function(file, index) {
      var reader = new FileReader();
      reader.onload = function(e) {
        var div = document.createElement('div');
        div.className = 'preview-image-item';
        div.setAttribute('data-image-type', 'new');
        div.innerHTML = '<img src="' + e.target.result + '" alt="Preview ' + (index + 1) + '"><button type="button" class="btn-delete-image" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>';
        previewGrid.appendChild(div);
      };
      reader.readAsDataURL(file);
    });
  };

  function populateExistingImages(images) {
    var previewGrid = document.getElementById('modalImagePreviewGrid');
    if (!previewGrid) return;
    previewGrid.innerHTML = '';
    var existingUrls = [];
    if (images && images.length > 0) {
      images.forEach(function(img, idx) {
        var url = typeof img === 'string' ? img : (img.image_url || '');
        if (!url || url.startsWith('data:')) return;
        existingUrls.push(url);
        var div = document.createElement('div');
        div.className = 'preview-image-item';
        div.setAttribute('data-image-type', 'existing');
        div.setAttribute('data-image-url', url);
        div.innerHTML = '<img src="' + url + '" alt="Image ' + (idx + 1) + '"><button type="button" class="btn-delete-image" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>';
        previewGrid.appendChild(div);
      });
    }
    $('#productModal').data('existingImages', existingUrls);
  }

  function loadProducts() {
    $.get('/admin/api/products', function(response) {
      if (response.success) {
        allProducts = response.products;
        renderProducts(allProducts);
        $('#filterResults strong').text(allProducts.length);
        console.log('Loaded', allProducts.length, 'products');
      }
    }).fail(function(xhr) {
      console.error('Failed to load products:', xhr.status);
    });
  }

  function loadCategorySpecs() {
    $.get('/admin/api/category-specs', function(response) {
      if (response.success) {
        categorySpecs = response.specs;
      }
    }).fail(function() {
      console.error('Failed to load category specs');
    });
  }

  function renderProducts(products) {
    var tbody = $('#productsTableBody');
    tbody.empty();
    if (products.length === 0) {
      tbody.append('<tr><td colspan="6"><div class="empty-state"><i class="fas fa-box-open"></i><p>No products found</p></div></td></tr>');
      return;
    }
    products.forEach(function(product) {
      var imageSrc = product.images && product.images[0] ? product.images[0].image_url : '/images/placeholder.jpg';
      var originalPriceHtml = '';
      if (product.original_price && product.original_price > product.price) {
        var discount = Math.round((1 - product.price / product.original_price) * 100);
        originalPriceHtml = '<span class="original-price">₦' + product.original_price.toFixed(2) + '</span><span class="discount-badge">-' + discount + '%</span>';
      }
      var stockClass = product.stock === 0 ? 'out-of-stock' : (product.stock < 10 ? 'low-stock' : 'in-stock');
      var statusClass = product.stock === 0 ? 'status-cancelled' : (product.stock < 10 ? 'status-pending' : 'status-delivered');
      var statusText = product.stock === 0 ? 'Out of Stock' : (product.stock < 10 ? 'Low Stock' : 'In Stock');
      var row = '<tr data-id="' + product.id + '">' +
        '<td><div class="product-cell"><img src="' + imageSrc + '" alt="' + product.name + '" class="product-thumb"><div class="product-info"><span class="product-name">' + product.name + '</span></div></div></td>' +
        '<td><span class="category-tag">' + (product.category || 'Uncategorized') + '</span></td>' +
        '<td><div class="price-cell"><span class="current-price">₦' + product.price.toFixed(2) + '</span>' + originalPriceHtml + '</div></td>' +
        '<td><span class="stock-count ' + stockClass + '">' + product.stock + '</span></td>' +
        '<td><span class="status-badge ' + statusClass + '">' + statusText + '</span></td>' +
        '<td><div class="action-buttons">' +
          '<button class="btn-icon view-btn" data-id="' + product.id + '" title="View"><i class="fas fa-eye"></i></button>' +
          '<button class="btn-icon edit-btn" data-id="' + product.id + '" title="Edit"><i class="fas fa-edit"></i></button>' +
          '<button class="btn-icon btn-delete delete-btn" data-id="' + product.id + '" title="Delete"><i class="fas fa-trash"></i></button>' +
        '</div></td></tr>';
      tbody.append(row);
    });
  }

  function initEventHandlers() {
    $('#addProductBtn').on('click', function() {
      openAddProductModal();
    });

    $(document).on('click', '.view-btn', function() {
      var productId = $(this).data('id');
      viewProduct(productId);
    });

    $(document).on('click', '.edit-btn', function() {
      var productId = $(this).data('id');
      console.log('Edit clicked, product id:', productId);
      openEditProductModal(productId);
    });

    $(document).on('click', '.delete-btn', function() {
      var productId = $(this).data('id');
      $('#deleteProductId').val(productId);
      $('#deleteModal').addClass('active');
      $('body').css('overflow', 'hidden');
    });

    $('#confirmDeleteBtn').on('click', function() {
      var productId = $('#deleteProductId').val();
      deleteProduct(productId);
    });

    $('#viewEditBtn').on('click', function() {
      if (currentViewId) {
        $('#viewModal').removeClass('active');
        openEditProductModal(currentViewId);
      }
    });

    $('#productForm').on('submit', function(e) {
      e.preventDefault();
      saveProduct();
    });

    $('#categoryFilter').on('change', applyFilters);
    $('#brandFilter').on('change', applyFilters);
    $('#modelFilter').on('change', applyFilters);
    $('#seriesFilter').on('change', applyFilters);
    $('#stockFilter').on('change', applyFilters);
    $('#searchInput').on('input', debounce(applyFilters, 300));

    $('#productCategory').on('change', function() {
      var catSlug = $(this).val();
      updateCascadeProgress('category', catSlug);
    });
  }

  function applyFilters() {
    var category = $('#categoryFilter').val();
    var brand = $('#brandFilter').val();
    var model = $('#modelFilter').val();
    var series = $('#seriesFilter').val();
    var stock = $('#stockFilter').val();
    var search = $('#searchInput').val().toLowerCase();

    var filtered = allProducts.filter(function(product) {
      if (category && product.categorySlug !== category) return false;
      if (brand && product.brand !== brand) return false;
      if (model && product.model_name !== model) return false;
      if (series && product.series !== series) return false;
      if (stock) {
        if (stock === 'in-stock' && product.stock <= 10) return false;
        if (stock === 'low-stock' && (product.stock <= 0 || product.stock >= 10)) return false;
        if (stock === 'out-of-stock' && product.stock > 0) return false;
      }
      if (search && product.name.toLowerCase().indexOf(search) === -1) return false;
      return true;
    });

    renderProducts(filtered);
    $('#filterResults strong').text(filtered.length);
  }

  function openAddProductModal() {
    isEditMode = false;
    modalCurrentType = '';
    $('#productModalTitle').html('<i class="fas fa-plus"></i> Add Product');
    $('#productForm')[0].reset();
    $('#productId').val('');
    $('#productBrand, #productModel, #productSeries').prop('disabled', true).empty().append('<option value="">-- Select --</option>');
    $('#modalTypeGroup').hide();
    $('#modalSpecsSection').hide();
    $('#modalImagePreviewGrid').empty();
    $('#productModal').removeData('existingImages');
    $('#submitBtn').prop('disabled', false).html('<i class="fas fa-spinner fa-spin" style="display: none;"></i> <span>Save Product</span>');
    resetCascadeProgress();
    $('#productModal').addClass('active');
    $('body').css('overflow', 'hidden');
  }

  function openEditProductModal(productId) {
    isEditMode = true;
    modalCurrentType = '';
    modalCurrentBrand = '';
    modalCurrentModel = '';
    modalCurrentSeries = '';
    $('#productModalTitle').html('<i class="fas fa-edit"></i> Edit Product');
    $('#submitBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> <span>Loading...</span>');

    $.get('/admin/api/products/' + productId, function(response) {
      if (!response.success) {
        console.error('Failed to load product:', response.message);
        $('#submitBtn').prop('disabled', false).html('<i class="fas fa-save"></i> <span>Save Product</span>');
        return;
      }
      var p = response.product;
      $('#productId').val(p.id);
      $('#productCategory').val(p.categorySlug || '');
      $('#productName').val(p.name || '');
      $('#productCondition').val(p.condition || 'new');
      $('#productSku').val(p.sku || '');
      $('#productShortDesc').val(p.short_description || '');
      $('#productDesc').val(p.description || '');
      $('#productPrice').val(p.price || '');
      $('#productOriginalPrice').val(p.original_price || '');
      $('#productStock').val(p.stock || 0);
      $('#productFeatured').prop('checked', p.is_featured || false);
      $('#productFlashSale').prop('checked', p.is_flash_sale || false);
      $('#productHotPick').prop('checked', p.is_hot_pick || false);

      var catSlug = p.categorySlug;
      var brandSlug = p.brand;
      var modelSlug = p.model_name;
      var seriesSlug = p.series;

      if (catSlug) {
        modalCurrentCategory = catSlug;
        var hasTypes = false;
        $.get('/admin/api/hierarchy/types/' + catSlug, function(resp) {
          if (resp.success && resp.types.length > 0) {
            hasTypes = true;
            $('#productType').empty().append('<option value="">-- Select Type --</option>');
            resp.types.forEach(function(t) {
              $('#productType').append('<option value="' + t + '">' + t + '</option>');
            });
            $('#modalTypeGroup').show();
          } else {
            $('#modalTypeGroup').hide();
          }
          populateBrandsForEdit(catSlug, brandSlug);
          populateModelsForEdit(catSlug, brandSlug, modelSlug);
          populateSeriesForEdit(catSlug, brandSlug, modelSlug, seriesSlug);
          updateCascadeProgress('series', catSlug);
          if (p.specs) renderSpecs(catSlug, p.specs);
          populateExistingImages(p.images);
          openModal();
        }).fail(function() {
          populateBrandsForEdit(catSlug, brandSlug);
          populateModelsForEdit(catSlug, brandSlug, modelSlug);
          populateSeriesForEdit(catSlug, brandSlug, modelSlug, seriesSlug);
          updateCascadeProgress('series', catSlug);
          if (p.specs) renderSpecs(catSlug, p.specs);
          populateExistingImages(p.images);
          openModal();
        });
      } else {
        populateExistingImages(p.images);
        openModal();
      }
    }).fail(function(xhr) {
      console.error('Failed to load product, status:', xhr.status);
      $('#submitBtn').prop('disabled', false).html('<i class="fas fa-save"></i> <span>Save Product</span>');
    });

    function openModal() {
      $('#productModal').addClass('active');
      $('body').css('overflow', 'hidden');
      $('#submitBtn').prop('disabled', false).html('<i class="fas fa-save"></i> <span>Save Product</span>');
    }
  }

  function populateBrandsForEdit(catSlug, selectedBrand) {
    if (!catSlug) return;
    $.get('/admin/api/hierarchy/brands/' + catSlug, function(resp) {
      var sel = $('#productBrand');
      sel.empty().append('<option value="">-- Select Brand --</option>');
      if (resp.success) {
        resp.brands.forEach(function(b) {
          sel.append('<option value="' + b.name + '"' + (b.name === selectedBrand ? ' selected' : '') + '>' + b.name + '</option>');
        });
      }
      sel.prop('disabled', false);
    });
  }

  function populateModelsForEdit(catSlug, brandSlug, selectedModel) {
    if (!catSlug || !brandSlug) return;
    $.get('/admin/api/hierarchy/models/' + catSlug + '/' + encodeURIComponent(brandSlug), function(resp) {
      var sel = $('#productModel');
      sel.empty().append('<option value="">-- Select Model --</option>');
      if (resp.success) {
        resp.models.forEach(function(m) {
          sel.append('<option value="' + m.name + '"' + (m.name === selectedModel ? ' selected' : '') + '>' + m.name + '</option>');
        });
      }
      sel.prop('disabled', false);
    });
  }

  function populateSeriesForEdit(catSlug, brandSlug, modelSlug, selectedSeries) {
    if (!catSlug || !brandSlug || !modelSlug) return;
    $.get('/admin/api/hierarchy/series/' + catSlug + '/' + encodeURIComponent(brandSlug) + '/' + encodeURIComponent(modelSlug), function(resp) {
      var sel = $('#productSeries');
      sel.empty().append('<option value="">-- Select Series --</option>');
      if (resp.success) {
        resp.series.forEach(function(s) {
          sel.append('<option value="' + s + '"' + (s === selectedSeries ? ' selected' : '') + '>' + s + '</option>');
        });
      }
      sel.prop('disabled', false);
    });
  }

  function viewProduct(productId) {
    currentViewId = productId;
    $('#viewModal').addClass('active');
    $('body').css('overflow', 'hidden');
    $('#viewModalBody').html('<div class="loading-state"><div class="spinner"></div><span>Loading...</span></div>');

    $.get('/admin/api/products/' + productId, function(response) {
      if (!response.success) return;
      var p = response.product;
      var imageSrc = p.images && p.images[0] ? p.images[0].image_url : '/images/placeholder.jpg';
      var imagesHtml = '';
      if (p.images && p.images.length > 0) {
        p.images.forEach(function(img) {
          imagesHtml += '<img src="' + img.image_url + '" class="gallery-thumb" onclick="changeMainImage(this.src)">';
        });
      }
      var tagsHtml = '';
      if (p.is_featured) tagsHtml += '<span class="tag tag-featured">Featured</span>';
      if (p.is_flash_sale) tagsHtml += '<span class="tag tag-sale">Flash Sale</span>';
      if (p.is_hot_pick) tagsHtml += '<span class="tag tag-hot">Hot Pick</span>';

      var html = '<div class="view-product-grid">' +
        '<div class="view-product-media">' +
          '<div class="main-image"><img id="viewMainImage" src="' + imageSrc + '" alt="' + p.name + '"></div>' +
          '<div class="image-gallery">' + imagesHtml + '</div>' +
        '</div>' +
        '<div class="view-product-details">' +
          '<div class="detail-header">' +
            '<h3 class="product-title">' + p.name + '</h3>' +
            '<p class="product-brand">' + (p.brand || 'N/A') + '</p>' +
            '<div class="product-pricing">' +
              '<span class="price-main">₦' + p.price.toFixed(2) + '</span>' +
              (p.original_price && p.original_price > p.price ? '<span class="price-original">₦' + p.original_price.toFixed(2) + '</span>' : '') +
            '</div>' +
            '<div class="tags-list">' + tagsHtml + '</div>' +
          '</div>' +
          '<div class="detail-info">' +
            '<div class="detail-row"><span class="detail-label">Category</span><span>' + (p.category || 'Uncategorized') + '</span></div>' +
            '<div class="detail-row"><span class="detail-label">Stock</span><span>' + p.stock + ' units</span></div>' +
            '<div class="detail-row"><span class="detail-label">SKU</span><span>' + (p.sku || 'N/A') + '</span></div>' +
            '<div class="detail-row"><span class="detail-label">Condition</span><span>' + (p.condition || 'New') + '</span></div>' +
          '</div>' +
          '<div class="detail-description">' +
            '<h4>Description</h4>' +
            '<p>' + (p.description || 'No description') + '</p>' +
          '</div>' +
        '</div>' +
      '</div>';
      $('#viewModalBody').html(html);
    });
  }

  function saveProduct() {
    var formData = new FormData($('#productForm')[0]);
    var previewItems = document.querySelectorAll('#modalImagePreviewGrid .preview-image-item');
    var imgUrls = [];
    previewItems.forEach(function(item) {
      var img = item.querySelector('img');
      if (img && img.src && !img.src.startsWith('data:')) {
        imgUrls.push(img.src);
      }
    });
    var existingData = $('#productModal').data('existingImages') || [];
    existingData.forEach(function(url) {
      if (url && !imgUrls.includes(url) && !url.startsWith('data:')) {
        imgUrls.push(url);
      }
    });
    if (imgUrls.length > 0) {
      formData.append('existingImages', JSON.stringify(imgUrls));
    }

    var url = isEditMode ? '/admin/api/products/' + $('#productId').val() + '?_method=PUT' : '/admin/api/products';
    var method = 'POST';

    $('#submitBtn').prop('disabled', true);
    $('#submitBtn .fa-spinner').show();

    $.ajax({
      url: url,
      type: method,
      data: formData,
      processData: false,
      contentType: false,
      success: function(response) {
        $('#submitBtn').prop('disabled', false);
        $('#submitBtn .fa-spinner').hide();
        if (response.success) {
          $('#productModal').removeClass('active');
          $('body').css('overflow', '');
          loadProducts();
          if (typeof showToast === 'function') {
            showToast(isEditMode ? 'Product updated successfully' : 'Product added successfully', 'success');
          }
        } else {
          if (typeof showToast === 'function') {
            showToast(response.message || 'Error saving product', 'error');
          }
        }
      },
      error: function(xhr) {
        $('#submitBtn').prop('disabled', false);
        $('#submitBtn .fa-spinner').hide();
        console.error('Save product error:', xhr.responseText);
        if (typeof showToast === 'function') {
          showToast('Error saving product', 'error');
        }
      }
    });
  }

  function deleteProduct(productId) {
    $('#confirmDeleteBtn').prop('disabled', true);
    $('#confirmDeleteBtn .fa-spinner').show();

    $.ajax({
      url: '/admin/api/products/' + productId,
      type: 'DELETE',
      success: function(response) {
        $('#confirmDeleteBtn').prop('disabled', false);
        $('#confirmDeleteBtn .fa-spinner').hide();
        if (response.success) {
          $('#deleteModal').removeClass('active');
          $('body').css('overflow', '');
          loadProducts();
          if (typeof showToast === 'function') {
            showToast('Product deleted successfully', 'success');
          }
        }
      },
      error: function() {
        $('#confirmDeleteBtn').prop('disabled', false);
        $('#confirmDeleteBtn .fa-spinner').hide();
        if (typeof showToast === 'function') {
          showToast('Error deleting product', 'error');
        }
      }
    });
  }

  function populateTypes(categorySlug) {
    $.get('/admin/api/hierarchy/types/' + categorySlug, function(response) {
      if (response.success && response.types.length > 0) {
        var select = $('#productType');
        select.empty().append('<option value="">-- Select Type --</option>');
        response.types.forEach(function(type) {
          select.append('<option value="' + type + '">' + type + '</option>');
        });
        $('#modalTypeGroup').show();
        $('#productBrand, #productModel, #productSeries').prop('disabled', true).empty().append('<option value="">-- Select --</option>');
      } else {
        $('#modalTypeGroup').hide();
        if (categorySlug) {
          populateBrands(categorySlug, modalCurrentBrand);
        }
      }
    }).fail(function() {
      console.error('Failed to load types for:', categorySlug);
    });
  }

  function populateBrands(categorySlug, selectedBrand) {
    if (!categorySlug) return;
    var url = '/admin/api/hierarchy/brands/' + categorySlug;
    if (modalCurrentType) {
      url += '?type=' + encodeURIComponent(modalCurrentType);
    }
    $.get(url, function(response) {
      var select = $('#productBrand');
      if (response.success && response.brands.length > 0) {
        select.empty().append('<option value="">-- Select Brand --</option>');
        response.brands.forEach(function(brand) {
          select.append('<option value="' + brand.name + '"' + (brand.name === selectedBrand ? ' selected' : '') + '>' + brand.name + '</option>');
        });
        select.prop('disabled', false);
      } else {
        select.empty().append('<option value="">-- No Brands Available --</option>');
        select.prop('disabled', true);
      }
    }).fail(function() {
      console.error('Failed to load brands for:', categorySlug);
    });
  }

  function populateModels(categorySlug, brandSlug, selectedModel) {
    if (!categorySlug || !brandSlug) return;
    var url = '/admin/api/hierarchy/models/' + categorySlug + '/' + encodeURIComponent(brandSlug);
    if (modalCurrentType) {
      url += '?type=' + encodeURIComponent(modalCurrentType);
    }
    $.get(url, function(response) {
      var select = $('#productModel');
      if (response.success && response.models.length > 0) {
        select.empty().append('<option value="">-- Select Model --</option>');
        response.models.forEach(function(model) {
          select.append('<option value="' + model.name + '"' + (model.name === selectedModel ? ' selected' : '') + '>' + model.name + '</option>');
        });
        select.prop('disabled', false);
      } else {
        select.empty().append('<option value="">-- No Models Available --</option>');
        select.prop('disabled', true);
      }
    }).fail(function() {
      console.error('Failed to load models for:', categorySlug, brandSlug);
    });
  }

  function populateSeries(categorySlug, brandSlug, modelSlug, selectedSeries) {
    if (!categorySlug || !brandSlug || !modelSlug) return;
    $.get('/admin/api/hierarchy/series/' + categorySlug + '/' + encodeURIComponent(brandSlug) + '/' + encodeURIComponent(modelSlug), function(response) {
      var select = $('#productSeries');
      if (response.success && response.series.length > 0) {
        select.empty().append('<option value="">-- Select Series --</option>');
        response.series.forEach(function(series) {
          select.append('<option value="' + series + '"' + (series === selectedSeries ? ' selected' : '') + '>' + series + '</option>');
        });
        select.prop('disabled', false);
      } else {
        select.empty().append('<option value="">-- No Series Available --</option>');
        select.prop('disabled', true);
      }
    }).fail(function() {
      console.error('Failed to load series for:', categorySlug, brandSlug, modelSlug);
    });
  }

  function renderSpecs(categorySlug, existingSpecs) {
    var catSpec = categorySpecs[categorySlug];
    if (!catSpec || !catSpec.specs) {
      $('#modalSpecsSection').hide();
      return;
    }
    var specsObj = catSpec.specs;
    var specKeys = Object.keys(specsObj);
    if (specKeys.length === 0) {
      $('#modalSpecsSection').hide();
      return;
    }
    $('#modalSpecsSection').show();
    $('#modalSpecsInfo').text(specKeys.length + ' fields available');
    var grid = $('#specsGrid');
    grid.empty();
    specKeys.forEach(function(key) {
      var spec = specsObj[key];
      var value = existingSpecs && existingSpecs[key] ? existingSpecs[key] : '';
      var inputHtml = '<div class="form-group">' +
        '<label for="spec_' + key + '">' + spec.label + '</label>' +
        '<input type="text" class="form-control" id="spec_' + key + '" name="specs[' + key + ']" value="' + value + '" placeholder="' + (spec.placeholder || spec.label) + '">' +
      '</div>';
      grid.append(inputHtml);
    });
  }

  function updateCascadeProgress(step, value) {
    var steps = ['category', 'type', 'brand', 'model', 'series'];
    var currentIndex = steps.indexOf(step);
    steps.forEach(function(s, i) {
      var el = document.getElementById('step-' + s);
      if (!el) return;
      if (i < currentIndex) {
        el.classList.add('completed');
        el.classList.remove('active');
      } else if (i === currentIndex) {
        el.classList.add('active');
        el.classList.remove('completed');
      } else {
        el.classList.remove('active', 'completed');
      }
    });
  }

  function resetCascadeProgress() {
    document.querySelectorAll('.cascade-step').forEach(function(el) {
      el.classList.remove('active', 'completed');
    });
    var first = document.getElementById('step-category');
    if (first) first.classList.add('active');
  }

  window.modalOnCategoryChange = function() {
    var catSlug = $('#productCategory').val();
    modalCurrentCategory = catSlug;
    modalCurrentType = '';
    $('#productBrand, #productModel, #productSeries').prop('disabled', true).empty().append('<option value="">-- Select --</option>');
    $('#modalTypeGroup').hide();
    $('#modalSpecsSection').hide();
    updateCascadeProgress('category', catSlug);
    if (catSlug) {
      populateTypes(catSlug);
    }
  };

  window.modalOnTypeChange = function() {
    var typeSlug = $('#productType').val();
    modalCurrentType = typeSlug;
    $('#productBrand, #productModel, #productSeries').prop('disabled', true).empty().append('<option value="">-- Select --</option>');
    updateCascadeProgress('type', typeSlug);
    if (typeSlug && modalCurrentCategory) {
      populateBrands(modalCurrentCategory, null);
    }
  };

  window.modalOnBrandChange = function() {
    var brandSlug = $('#productBrand').val();
    modalCurrentBrand = brandSlug;
    modalCurrentModel = '';
    modalCurrentSeries = '';
    $('#productModel, #productSeries').prop('disabled', true).empty().append('<option value="">-- Select --</option>');
    updateCascadeProgress('brand', brandSlug);
    if (brandSlug && modalCurrentCategory) {
      populateModels(modalCurrentCategory, brandSlug);
    }
  };

  window.modalOnModelChange = function() {
    var modelSlug = $('#productModel').val();
    modalCurrentModel = modelSlug;
    modalCurrentSeries = '';
    $('#productSeries').prop('disabled', true).empty().append('<option value="">-- Select --</option>');
    updateCascadeProgress('model', modelSlug);
    if (modelSlug && modalCurrentCategory && modalCurrentBrand) {
      populateSeries(modalCurrentCategory, modalCurrentBrand, modelSlug);
    }
  };

  $('#productSeries').on('change', function() {
    var seriesSlug = $(this).val();
    modalCurrentSeries = seriesSlug;
    updateCascadeProgress('series', seriesSlug);
    if (seriesSlug) {
      renderSpecs(modalCurrentCategory);
    }
  });
  } catch(e) {
    console.error('Products page initialization error:', e);
  }
});
</script>
