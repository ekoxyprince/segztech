<div class="page-header">
  <div>
    <h2>Settings</h2>
    <p class="page-subtitle">Configure your store settings</p>
  </div>
</div>

<div class="settings-grid">
  <form method="POST" action="/admin/settings">
    <div class="form-card">
      <h3><i class="fas fa-cog"></i> General Settings</h3>
      <div class="form-group">
        <label for="site_name">Store Name</label>
        <input type="text" class="form-control" id="site_name" name="site_name" value="<%= settings.site_name %>" placeholder="Enter store name">
      </div>
      <div class="form-group">
        <label for="site_email">Store Email</label>
        <input type="email" class="form-control" id="site_email" name="site_email" value="<%= settings.site_email %>" placeholder="Enter store email">
      </div>
      <div class="form-group">
        <label for="site_phone">Store Phone</label>
        <input type="text" class="form-control" id="site_phone" name="site_phone" value="<%= settings.site_phone %>" placeholder="Enter store phone">
      </div>
      <div class="form-group">
        <label for="currency_symbol">Currency Symbol</label>
        <input type="text" class="form-control" id="currency_symbol" name="currency_symbol" value="<%= settings.currency_symbol %>" placeholder="e.g., ₦" style="max-width:100px">
      </div>
      <div class="form-group">
        <label for="currency">Currency Code</label>
        <input type="text" class="form-control" id="currency" name="currency" value="<%= settings.currency %>" placeholder="e.g., NGN" style="max-width:120px">
      </div>
      <div class="form-group">
        <label for="site_address">Store Address</label>
        <textarea class="form-control" id="site_address" name="site_address" rows="3" placeholder="Enter store address"><%= settings.site_address %></textarea>
      </div>
    </div>

    <div class="form-card">
      <h3><i class="fas fa-credit-card"></i> Payment Methods</h3>
      <div class="settings-section">
        <label class="checkbox-label">
          <input type="checkbox" id="payment_paystack" name="payment_paystack" <%= settings.payment_paystack ? 'checked' : '' %>>
          <span>Paystack</span>
        </label>
        <p class="setting-desc">Accept payments via Paystack gateway</p>
      </div>
      <div class="settings-section">
        <label class="checkbox-label">
          <input type="checkbox" id="payment_whatsapp" name="payment_whatsapp" <%= settings.payment_whatsapp ? 'checked' : '' %>>
          <span>WhatsApp Orders</span>
        </label>
        <p class="setting-desc">Allow customers to order via WhatsApp</p>
      </div>
      <div class="form-group">
        <label for="whatsapp_number">WhatsApp Number</label>
        <input type="text" class="form-control" id="whatsapp_number" name="whatsapp_number" value="<%= settings.whatsapp_number %>" placeholder="Enter WhatsApp number">
      </div>
    </div>

    <div class="form-card">
      <h3><i class="fas fa-bell"></i> Notifications</h3>
      <div class="settings-section">
        <label class="checkbox-label">
          <input type="checkbox" id="notify_email" name="notify_email" <%= settings.notify_email ? 'checked' : '' %>>
          <span>Email Notifications</span>
        </label>
        <p class="setting-desc">Receive email notifications for new orders</p>
      </div>
      <div class="settings-section">
        <label class="checkbox-label">
          <input type="checkbox" id="notify_new_product" name="notify_new_product" <%= settings.notify_new_product ? 'checked' : '' %>>
          <span>New Product Notifications</span>
        </label>
        <p class="setting-desc">Notify users when new products are added</p>
      </div>
    </div>

    <button type="submit" class="btn btn-primary">
      <i class="fas fa-save"></i> Save All Settings
    </button>
  </form>
</div>

<style>
.settings-grid form { max-width: 700px; margin-top: 20px; }
.settings-grid .form-card { background: var(--bg-secondary); border-radius: var(--radius-lg); padding: 24px; margin-bottom: 20px; }
.settings-grid .form-card h3 { margin: 0 0 20px 0; font-size: 16px; display: flex; align-items: center; gap: 10px; }
.settings-grid .form-card h3 i { color: var(--primary); }
.settings-section { margin-bottom: 15px; }
.setting-desc { font-size: 12px; color: var(--text-muted); margin-top: 5px; margin-left: 28px; }
.checkbox-label { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.checkbox-label input[type="checkbox"] { width: 18px; height: 18px; cursor: pointer; }
</style>
