<!-- Page Header -->
<div class="page-header">
  <div>
    <h2><i class="fas fa-bolt"></i> Flash Sales</h2>
    <p class="text-muted">Manage flash sale periods with scheduled start and end dates</p>
  </div>
  <div class="page-actions">
    <a href="/admin/flash-sales/new" class="btn btn-primary">
      <i class="fas fa-plus"></i> Add Flash Sale
    </a>
  </div>
</div>

<% if (flashSales.length > 0) { %>
<div class="flash-sales-list">
  <% flashSales.forEach(sale => { %>
    <% const now = new Date(); const start = new Date(sale.start_date); const end = new Date(sale.end_date); const isActive = sale.is_active && start <= now && end >= now; const isScheduled = sale.is_active && start > now; const isExpired = end < now || !sale.is_active; %>
    <div class="flash-sale-card <%= isActive ? 'active' : (isScheduled ? 'scheduled' : 'expired') %>">
      <div class="sale-status">
        <% if (isActive) { %>
          <span class="status-badge status-active"><i class="fas fa-bolt"></i> Active</span>
        <% } else if (isScheduled) { %>
          <span class="status-badge status-scheduled"><i class="fas fa-clock"></i> Scheduled</span>
        <% } else { %>
          <span class="status-badge status-expired"><i class="fas fa-check-circle"></i> Ended</span>
        <% } %>
      </div>

      <% if (sale.image) { %>
        <div class="sale-image">
          <img src="<%= sale.image %>" alt="<%= sale.title %>">
        </div>
      <% } %>

      <div class="sale-info">
        <h3><%= sale.title %></h3>
        <% if (sale.subtitle) { %><p class="sale-subtitle"><%= sale.subtitle %></p><% } %>
        <% if (sale.description) { %><p class="sale-description"><%= sale.description %></p><% } %>
        
        <div class="sale-dates">
          <div class="date-block">
            <span class="date-label"><i class="fas fa-play"></i> Start</span>
            <span class="date-value"><%= new Date(sale.start_date).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
          </div>
          <div class="date-block">
            <span class="date-label"><i class="fas fa-stop"></i> End</span>
            <span class="date-value"><%= new Date(sale.end_date).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
          </div>
        </div>
      </div>

      <div class="sale-actions">
        <a href="/admin/flash-sales/<%= sale.id %>/edit" class="btn btn-sm btn-outline">
          <i class="fas fa-edit"></i> Edit
        </a>
        <form action="/admin/flash-sales/<%= sale.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this flash sale?')">
          <button type="submit" class="btn btn-sm btn-danger">
            <i class="fas fa-trash"></i> Delete
          </button>
        </form>
      </div>
    </div>
  <% }) %>
</div>
<% } else { %>
<div class="empty-state">
  <i class="fas fa-bolt"></i>
  <p>No flash sales yet</p>
  <a href="/admin/flash-sales/new" class="btn btn-primary">Create Your First Flash Sale</a>
</div>
<% } %>

<style>
.flash-sales-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.flash-sale-card {
  display: flex;
  align-items: center;
  gap: 20px;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: 20px;
  border: 1px solid var(--border);
  transition: all 0.2s;
}

.flash-sale-card.active {
  border-left: 4px solid #f59e0b;
}

.flash-sale-card.scheduled {
  border-left: 4px solid #3b82f6;
}

.flash-sale-card.expired {
  border-left: 4px solid #6b7280;
  opacity: 0.7;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
}

.status-active { background: #fef3c7; color: #92400e; }
.status-scheduled { background: #dbeafe; color: #1e40af; }
.status-expired { background: #f3f4f6; color: #4b5563; }

.sale-image {
  width: 100px;
  height: 70px;
  border-radius: var(--radius);
  overflow: hidden;
  flex-shrink: 0;
}

.sale-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.sale-info {
  flex: 1;
  min-width: 0;
}

.sale-info h3 {
  font-size: 16px;
  font-weight: 600;
  margin: 0 0 4px;
}

.sale-subtitle {
  font-size: 13px;
  color: var(--text-muted);
  margin: 0 0 4px;
}

.sale-description {
  font-size: 13px;
  color: var(--text-secondary);
  margin: 0 0 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sale-dates {
  display: flex;
  gap: 20px;
  margin-top: 8px;
}

.date-block {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.date-label {
  font-size: 11px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.date-value {
  font-size: 13px;
  font-weight: 500;
}

.sale-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--text-muted);
}

.empty-state i {
  font-size: 48px;
  margin-bottom: 16px;
  color: var(--text-muted);
}

.empty-state p {
  font-size: 16px;
  margin-bottom: 20px;
}

@media (max-width: 768px) {
  .flash-sale-card {
    flex-direction: column;
    align-items: flex-start;
  }
  .sale-dates {
    flex-direction: column;
    gap: 8px;
  }
  .sale-image {
    width: 100%;
    height: 120px;
  }
}
</style>
