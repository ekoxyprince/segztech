<!-- Page Header -->
<div class="page-header">
  <div>
    <h2>Products</h2>
    <p class="page-subtitle">Manage your product inventory</p>
  </div>
</div>

<!-- Filters -->
<div class="filters-bar">
  <div class="filter-group">
    <label>Category</label>
    <select class="filter-select" id="categoryFilter">
      <option value="">All Categories</option>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.slug %>"><%= cat.name %></option>
      <% }); %>
    </select>
  </div>
  <div class="filter-group">
    <label>Stock</label>
    <select class="filter-select" id="stockFilter">
      <option value="">All Stock</option>
      <option value="in-stock">In Stock</option>
      <option value="low-stock">Low Stock</option>
      <option value="out-of-stock">Out of Stock</option>
    </select>
  </div>
  <div class="filter-divider"></div>
  <div class="filter-search">
    <i class="fas fa-search"></i>
    <input type="text" id="searchInput" placeholder="Search products...">
  </div>
  <div class="filter-results" id="filterResults">
    <strong>0</strong> products found
  </div>
</div>
      <div class="filter-group">
        <label>Brand</label>
        <select class="filter-select" id="brandFilter" disabled>
          <option value="">All Brands</option>
        </select>
      </div>
  <div class="filter-group">
    <label>Brand</label>
    <select class="filter-select" id="brandFilter" disabled>
      <option value="">All Brands</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Model</label>
    <select class="filter-select" id="modelFilter" disabled>
      <option value="">All Models</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Series</label>
    <select class="filter-select" id="seriesFilter" disabled>
      <option value="">All Series</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Stock</label>
    <select class="filter-select" id="stockFilter">
      <option value="">All Stock</option>
      <option value="in-stock">In Stock</option>
      <option value="low-stock">Low Stock</option>
      <option value="out-of-stock">Out of Stock</option>
    </select>
  </div>
  <div class="filter-divider"></div>
  <div class="filter-search">
    <i class="fas fa-search"></i>
    <input type="text" id="searchInput" placeholder="Search products...">
  </div>
  <div class="filter-results" id="filterResults">
    <strong>0</strong> products found
  </div>
</div>

<!-- Products Table -->
<div class="table-card">
  <div id="loadingState" class="loading-state" style="display: none;">
    <div class="spinner"></div>
    <span>Loading products...</span>
  </div>
  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Category</th>
          <th>Price</th>
          <th>Stock</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="productsTableBody">
        <% if (products && products.length > 0) { %>
          <% products.forEach(product => { %>
            <tr data-id="<%= product.id %>">
              <td>
                <div class="product-cell">
                  <img src="<%= product.images && product.images[0] ? product.images[0].image_url : '/images/placeholder.jpg' %>" alt="<%= product.name %>" class="product-thumb">
                  <div class="product-info">
                    <span class="product-name"><%= product.name %></span>
                  </div>
                </div>
              </td>
              <td><span class="category-tag"><%= product.category || 'Uncategorized' %></span></td>
              <td>
                <div class="price-cell">
                  <span class="current-price">₦<%= product.price.toFixed(2) %></span>
                  <% if (product.originalPrice > product.price) { %>
                    <span class="original-price">₦<%= product.originalPrice.toFixed(2) %></span>
                    <span class="discount-badge">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%</span>
                  <% } %>
                </div>
              </td>
              <td><span class="stock-count <%= product.stock === 0 ? 'out-of-stock' : (product.stock < 10 ? 'low-stock' : 'in-stock') %>"><%= product.stock %></span></td>
              <td>
                <span class="status-badge <%= product.stock === 0 ? 'status-cancelled' : (product.stock < 10 ? 'status-pending' : 'status-delivered') %>">
                  <%= product.stock === 0 ? 'Out of Stock' : (product.stock < 10 ? 'Low Stock' : 'In Stock') %>
                </span>
              </td>
              <td>
                <div class="action-buttons">
                  <button class="btn-icon view-btn" data-id="<%= product.id %>" title="View">
                    <i class="fas fa-eye"></i>
                  </button>
                  <button class="btn-icon edit-btn" data-id="<%= product.id %>" title="Edit">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button class="btn-icon btn-delete delete-btn" data-id="<%= product.id %>" title="Delete">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6">
              <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <p>No products found</p>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- View Product Modal -->
<div class="modal-overlay" id="viewModal">
  <div class="modal modal-xl">
    <div class="modal-header">
      <h3><i class="fas fa-eye"></i> Product Details</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body" id="viewModalBody">
      <div class="loading-state">
        <div class="spinner"></div>
        <span>Loading...</span>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Close</button>
      <button type="button" class="btn btn-primary" id="viewEditBtn">
        <i class="fas fa-edit"></i> Edit Product
      </button>
    </div>
  </div>
</div>

<!-- Product Form Modal -->
<div class="modal-overlay" id="productModal">
  <div class="modal modal-xl">
    <div class="modal-header">
      <h3 id="productModalTitle"><i class="fas fa-plus"></i> Add Product</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="productForm" enctype="multipart/form-data">
      <div class="modal-body">
        <input type="hidden" id="productId" name="id">
        
        <!-- Cascade Progress -->
        <div class="cascade-progress" id="cascadeProgress">
          <span class="cascade-step active" id="step-category">Category</span>
          <span class="cascade-arrow">→</span>
          <span class="cascade-step" id="step-type">Type</span>
          <span class="cascade-arrow">→</span>
          <span class="cascade-step" id="step-brand">Brand</span>
          <span class="cascade-arrow">→</span>
          <span class="cascade-step" id="step-model">Model</span>
          <span class="cascade-arrow">→</span>
          <span class="cascade-step" id="step-series">Series</span>
        </div>
        
        <div class="form-grid">
          <div class="form-section">
            <h4><i class="fas fa-sitemap"></i> Product Hierarchy</h4>
            
            <div class="form-group">
              <label for="productCategory">Category *</label>
              <select class="form-control" id="productCategory" name="category" required onchange="modalOnCategoryChange()">
                <option value="">-- Select Category --</option>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat.slug %>" data-hastypes="<%= hierarchy.getTypes(cat.slug).length > 0 ? 'true' : 'false' %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
            
            <div class="form-group" id="modalTypeGroup" style="display:none;">
              <label for="productType">Product Type *</label>
              <select class="form-control" id="productType" name="subcategory" onchange="modalOnTypeChange()">
                <option value="">-- Select Type --</option>
              </select>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="productBrand">Brand *</label>
                <select class="form-control" id="productBrand" name="brand" required disabled onchange="modalOnBrandChange()">
                  <option value="">-- Select Brand --</option>
                </select>
              </div>
              <div class="form-group">
                <label for="productModel">Model Line *</label>
                <select class="form-control" id="productModel" name="model" required disabled onchange="modalOnModelChange()">
                  <option value="">-- Select Model --</option>
                </select>
              </div>
            </div>
            
            <div class="form-group">
              <label for="productSeries">Specific Series/Variant *</label>
              <select class="form-control" id="productSeries" name="series" required disabled>
                <option value="">-- Select Series --</option>
              </select>
            </div>
          </div>
          
          <div class="form-section">
            <h4><i class="fas fa-info-circle"></i> Basic Info</h4>
            
            <div class="form-group">
              <label for="productName">Product Name *</label>
              <input type="text" class="form-control" id="productName" name="name" required placeholder="e.g., HP EliteBook 840 G10 Core i7 16GB">
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="productCondition">Condition *</label>
                <select class="form-control" id="productCondition" name="condition">
                  <option value="new">New</option>
                  <option value="used_like_new">Used - Like New</option>
                  <option value="used_good">Used - Good</option>
                  <option value="used_fair">Used - Fair</option>
                  <option value="refurbished">Refurbished</option>
                </select>
              </div>
              <div class="form-group">
                <label for="productSku">SKU</label>
                <input type="text" class="form-control" id="productSku" name="sku" placeholder="Auto-generated if empty">
              </div>
            </div>
            
            <div class="form-group">
              <label for="productShortDesc">Short Description</label>
              <input type="text" class="form-control" id="productShortDesc" name="shortDescription" maxlength="200">
            </div>
            
            <div class="form-group">
              <label for="productDesc">Full Description *</label>
              <textarea class="form-control" id="productDesc" name="description" rows="4" required></textarea>
            </div>
          </div>
          
          <div class="form-section">
            <h4><i class="fas fa-dollar-sign"></i> Pricing & Stock</h4>
            
            <div class="form-row">
              <div class="form-group">
                <label for="productPrice">Price ($) *</label>
                <input type="number" class="form-control" id="productPrice" name="price" step="0.01" min="0" required>
              </div>
              <div class="form-group">
                <label for="productOriginalPrice">Original Price ($)</label>
                <input type="number" class="form-control" id="productOriginalPrice" name="originalPrice" step="0.01" min="0">
              </div>
            </div>
            
            <div class="form-group">
              <label for="productStock">Stock Quantity *</label>
              <input type="number" class="form-control" id="productStock" name="stock" min="0" required>
            </div>
            
            <div class="form-group">
              <label>Product Tags</label>
              <div class="checkbox-group">
                <label class="checkbox-label"><input type="checkbox" id="productFeatured" name="isFeatured"><span>Featured</span></label>
                <label class="checkbox-label"><input type="checkbox" id="productFlashSale" name="isFlashSale"><span>Flash Sale</span></label>
                <label class="checkbox-label"><input type="checkbox" id="productHotPick" name="isHotPick"><span>Hot Pick</span></label>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Dynamic Specs -->
        <div class="form-section full-width" id="modalSpecsSection" style="display:none;">
          <h4><i class="fas fa-microchip"></i> Technical Specifications <small id="modalSpecsInfo" style="color:var(--text-muted);font-weight:normal;"></small></h4>
          <div class="specs-grid" id="specsGrid"></div>
        </div>
        
        <!-- Images -->
        <div class="form-section full-width">
          <h4><i class="fas fa-image"></i> Images</h4>
          <div class="upload-area" id="modalImageUploadArea">
            <input type="file" id="productImages" name="images" multiple accept="image/*" onchange="modalPreviewImages(event)">
            <div class="upload-placeholder">
              <i class="fas fa-cloud-upload-alt"></i>
              <p>Click or drag images here to upload</p>
              <span>JPG, PNG, WebP (Max 5MB each)</span>
            </div>
            <div class="image-preview-grid" id="modalImagePreviewGrid"></div>
          </div>
        </div>

        <!-- Video -->
        <div class="form-section full-width">
          <h4><i class="fas fa-video"></i> Product Video</h4>
          <div class="upload-area">
            <input type="file" id="productVideo" name="video" accept="video/*">
            <div class="upload-placeholder">
              <i class="fas fa-video"></i>
              <p>Upload product video (optional)</p>
              <span>MP4, WebM (Max 50MB)</span>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline close-modal">Cancel</button>
        <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
          <i class="fas fa-spinner fa-spin" style="display: none;"></i>
          <span>Save Product</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h3><i class="fas fa-trash"></i> Delete Product</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to delete this product? This action cannot be undone.</p>
      <input type="hidden" id="deleteProductId">
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Cancel</button>
      <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
        <i class="fas fa-spinner fa-spin" style="display: none;"></i>
        <span>Delete</span>
      </button>
    </div>
  </div>
</div>

<style>
.cascade-progress {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 20px;
  padding: 12px 16px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  font-size: 13px;
  flex-wrap: wrap;
}
.cascade-step {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 20px;
  background: var(--border);
  color: var(--text-muted);
  transition: all 0.3s;
  font-weight: 500;
}
.cascade-step.active {
  background: var(--primary);
  color: white;
}
.cascade-step.completed {
  background: #10b981;
  color: white;
}
.cascade-arrow {
  color: var(--text-muted);
  font-size: 11px;
}
.specs-grid .form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 768px) {
  .specs-grid .form-row { grid-template-columns: 1fr; }
}
</style>

<script>
$(document).ready(function() {
  var allProducts = [];
  var currentViewId = null;
  var isEditMode = false;
  var uploadedImages = [];
  var uploadedVideo = null;
  var categorySpecs = {};
  var modalCurrentCategory = '';
  var modalCurrentType = '';
  var modalCurrentBrand = '';
  var modalCurrentModel = '';
  var modalCurrentSeries = '';
  
  loadProducts();
  loadCategorySpecs();
  initEventHandlers();
  
  // Image preview for modal
  window.modalPreviewImages = function(event) {
    const files = event.target.files;
    const previewGrid = document.getElementById('modalImagePreviewGrid') || document.getElementById('imagePreviewGrid');
    if (!previewGrid) return;
    previewGrid.innerHTML = '';
    
    Array.from(files).forEach((file, index) => {
      const reader = new FileReader();
      reader.onload = function(e) {
        const div = document.createElement('div');
        div.className = 'preview-image-item';
        div.innerHTML = `
          <img src="${e.target.result}" alt="Preview ${index + 1}">
          <button type="button" class="btn-delete-image" onclick="this.parentElement.remove()">
            <i class="fas fa-times"></i>
          </button>
        `;
        previewGrid.appendChild(div);
      };
      reader.readAsDataURL(file);
    });
  };
});

</script>