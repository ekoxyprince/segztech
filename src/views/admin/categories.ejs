<!-- Page Header -->
<div class="page-header">
  <div>
    <h2>Manage Categories</h2>
    <p class="text-muted">Organize your products with categories</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" id="openCategoryModalBtn">
      <i class="fas fa-plus"></i> Add Category
    </button>
  </div>
</div>

<!-- Categories Grid -->
<div class="categories-grid" id="categoriesGrid">
  <div id="loadingState" class="loading-state" style="display: none; grid-column: 1 / -1;">
    <div class="spinner"></div>
    <span>Loading categories...</span>
  </div>
  <% if (categories && categories.length > 0) { %>
    <% categories.forEach(category => { %>
      <div class="category-card" data-id="<%= category.id %>">
        <div class="category-icon">
          <i class="fas fa-tag"></i>
        </div>
        <div class="category-details">
          <h4><%= category.name %></h4>
          <p class="category-slug"><%= category.slug %></p>
          <p class="category-count"><%= category.count || 0 %> products</p>
        </div>
        <div class="category-actions">
          <button class="btn-icon edit-cat-btn" data-id="<%= category.id %>" title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button class="btn-icon view-cat-btn" data-id="<%= category.id %>" title="View">
            <i class="fas fa-eye"></i>
          </button>
          <button class="btn-icon btn-delete delete-cat-btn" data-id="<%= category.id %>" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="no-categories">
      <i class="fas fa-tags"></i>
      <p>No categories found</p>
      <button class="btn btn-primary" id="addFirstCategoryBtn">Add First Category</button>
    </div>
  <% } %>
</div>

<!-- View Category Modal -->
<div class="modal-overlay" id="viewCategoryModal">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-eye"></i> Category Details</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body" id="viewCategoryBody">
      <div class="loading-state">
        <div class="spinner"></div>
        <span>Loading...</span>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Close</button>
      <button type="button" class="btn btn-primary" id="viewEditCategoryBtn">
        <i class="fas fa-edit"></i> Edit
      </button>
    </div>
  </div>
</div>

<!-- Category Add/Edit Modal -->
<div class="modal-overlay" id="categoryModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="categoryModalTitle"><i class="fas fa-plus"></i> Add Category</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="categoryForm">
      <div class="modal-body">
        <div class="form-group">
          <label for="categoryName">Category Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="categoryName" name="name" placeholder="e.g., Laptops" required>
          <div class="invalid-feedback" id="categoryNameError"></div>
        </div>
        <div class="form-group">
          <label for="categorySlug">Slug (URL) <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="categorySlug" name="slug" placeholder="e.g., laptops" required>
          <small class="form-text text-muted">URL-friendly slug (e.g., laptops, electronics)</small>
          <div class="invalid-feedback" id="categorySlugError"></div>
        </div>
        <div class="form-group">
          <label for="categoryDescription">Description</label>
          <textarea class="form-control" id="categoryDescription" name="description" placeholder="Category description..." rows="4"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline close-modal">Cancel</button>
        <button type="submit" class="btn btn-primary" id="categorySubmitBtn">
          <i class="fas fa-spinner fa-spin" style="display: none;"></i>
          <span>Save Category</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteCategoryModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h3><i class="fas fa-exclamation-triangle"></i> Confirm Delete</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to delete this category? This action cannot be undone.</p>
      <input type="hidden" id="deleteCategoryId">
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Cancel</button>
      <button type="button" class="btn btn-danger" id="confirmCategoryDeleteBtn">
        <i class="fas fa-spinner fa-spin" style="display: none;"></i>
        <span>Delete</span>
      </button>
    </div>
  </div>
</div>

<script>
$(document).ready(function() {
  var currentEditId = null;
  var currentViewId = null;
  var slugManuallyEdited = false;
  
  loadCategories();
  
  function openCategoryModal(isEdit) {
    currentEditId = isEdit || null;
    slugManuallyEdited = isEdit ? true : false;
    
    $('#categoryModal').addClass('active');
    $('body').css('overflow', 'hidden');
    
    if (isEdit) {
      $('#categoryModalTitle').html('<i class="fas fa-edit"></i> Edit Category');
      $('#categorySubmitBtn').find('span').text('Update Category');
    } else {
      $('#categoryModalTitle').html('<i class="fas fa-plus"></i> Add Category');
      $('#categorySubmitBtn').find('span').text('Save Category');
    }
    
    $('#categoryForm')[0].reset();
    $('#categoryForm').find('.is-invalid').removeClass('is-invalid');
  }
  
  function closeCategoryModal() {
    $('#categoryModal').removeClass('active');
    $('body').css('overflow', '');
    currentEditId = null;
    slugManuallyEdited = false;
  }
  
  function openViewCategoryModal(id) {
    currentViewId = id;
    $('#viewCategoryModal').addClass('active');
    $('body').css('overflow', 'hidden');
    $('#viewCategoryBody').html('<div class="loading-state"><div class="spinner"></div><span>Loading...</span></div>');
    
    $.get('/admin/api/categories/' + id)
      .done(function(data) {
        if (data.success) {
          var cat = data.category;
          $('#viewCategoryBody').html(`
            <div class="category-detail-card">
              <div class="detail-header">
                <div class="detail-icon">
                  <i class="fas fa-tag"></i>
                </div>
                <div class="detail-title">
                  <h4>${cat.name}</h4>
                  <span class="slug-text">/${cat.slug}</span>
                </div>
              </div>
              <div class="detail-stats">
                <div class="stat-item">
                  <i class="fas fa-box"></i>
                  <span><strong>${cat.count || 0}</strong> Products</span>
                </div>
              </div>
              ${cat.description ? `
              <div class="detail-section">
                <h5><i class="fas fa-align-left"></i> Description</h5>
                <p>${cat.description}</p>
              </div>
              ` : ''}
              <div class="detail-meta">
                <div class="meta-item">
                  <span class="meta-label">Created</span>
                  <span class="meta-value">${formatDate(cat.createdAt)}</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Last Updated</span>
                  <span class="meta-value">${formatDate(cat.updatedAt)}</span>
                </div>
              </div>
            </div>
          `);
        }
      })
      .fail(function() {
        $('#viewCategoryBody').html('<div class="alert alert-danger">Failed to load category details</div>');
      });
  }
  
  function closeViewCategoryModal() {
    $('#viewCategoryModal').removeClass('active');
    $('body').css('overflow', '');
    currentViewId = null;
  }
  
  function editCategory(id) {
    currentEditId = id;
    slugManuallyEdited = true;
    $('#categoryModal').addClass('active');
    $('body').css('overflow', 'hidden');
    $('#categoryModalTitle').html('<i class="fas fa-edit"></i> Edit Category');
    $('#categorySubmitBtn').find('span').text('Update Category');
    
    $('#viewCategoryModal').removeClass('active');
    
    $.get('/admin/api/categories/' + id)
      .done(function(data) {
        if (data.success) {
          $('#categoryName').val(data.category.name);
          $('#categorySlug').val(data.category.slug);
          $('#categoryDescription').val(data.category.description || '');
        }
      })
      .fail(function() {
        showToast('Failed to load category', 'error');
        closeCategoryModal();
      });
  }
  
  function deleteCategory(id) {
    $('#deleteCategoryId').val(id);
    $('#deleteCategoryModal').addClass('active');
    $('body').css('overflow', 'hidden');
  }
  
  function confirmDeleteCategory() {
    var id = $('#deleteCategoryId').val();
    var $btn = $('#confirmCategoryDeleteBtn');
    var $icon = $btn.find('i');
    var $span = $btn.find('span');
    
    $btn.prop('disabled', true);
    $icon.addClass('fa-spin');
    $icon.show();
    $span.text('Deleting...');
    
    $.ajax({
      url: '/admin/api/categories/' + id,
      method: 'DELETE'
    })
    .done(function(data) {
      if (data.success) {
        showToast('Category deleted successfully', 'success');
        $('#deleteCategoryModal').removeClass('active');
        $('body').css('overflow', '');
        loadCategories();
      }
    })
    .fail(function() {
      showToast('Failed to delete category', 'error');
    })
    .always(function() {
      $btn.prop('disabled', false);
      $icon.removeClass('fa-spin');
      $icon.hide();
      $span.text('Delete');
    });
  }
  
  function loadCategories() {
    $('#loadingState').show();
    $('.category-card, .no-categories').hide();
    
    $.get('/admin/api/categories')
      .done(function(data) {
        $('#loadingState').hide();
        
        if (!data.categories || data.categories.length === 0) {
          $('#categoriesGrid').html(`
            <div class="no-categories">
              <i class="fas fa-tags"></i>
              <p>No categories found</p>
              <button class="btn btn-primary" id="addFirstCategoryBtn">Add First Category</button>
            </div>
          `);
          return;
        }
        
        var html = data.categories.map(function(cat) {
          return `
            <div class="category-card" data-id="${cat.id}">
              <div class="category-icon">
                <i class="fas fa-tag"></i>
              </div>
              <div class="category-details">
                <h4>${cat.name}</h4>
                <p class="category-slug">${cat.slug}</p>
                <p class="category-count">${cat.count || 0} products</p>
              </div>
              <div class="category-actions">
                <button class="btn-icon edit-cat-btn" data-id="${cat.id}" title="Edit">
                  <i class="fas fa-edit"></i>
                </button>
                <button class="btn-icon view-cat-btn" data-id="${cat.id}" title="View">
                  <i class="fas fa-eye"></i>
                </button>
                <button class="btn-icon btn-delete delete-cat-btn" data-id="${cat.id}" title="Delete">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
          `;
        }).join('');
        
        $('#categoriesGrid').html(html);
      })
      .fail(function() {
        $('#loadingState').hide();
        showToast('Failed to load categories', 'error');
      });
  }
  
  $('#categoryForm').on('submit', function(e) {
    e.preventDefault();
    
    var name = $('#categoryName').val().trim();
    var slug = $('#categorySlug').val().trim();
    var description = $('#categoryDescription').val();
    
    if (!name) {
      $('#categoryName').addClass('is-invalid');
      return;
    }
    
    if (!slug) {
      $('#categorySlug').addClass('is-invalid');
      return;
    }
    
    var formData = {
      name: name,
      slug: slug.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''),
      description: description
    };
    
    var url = currentEditId ? '/admin/api/categories/' + currentEditId : '/admin/api/categories';
    var method = currentEditId ? 'PUT' : 'POST';
    
    var $btn = $('#categorySubmitBtn');
    var $icon = $btn.find('i');
    var $span = $btn.find('span');
    
    $btn.prop('disabled', true);
    $icon.addClass('fa-spin');
    $icon.show();
    $span.text(currentEditId ? 'Updating...' : 'Saving...');
    
    $.ajax({
      url: url,
      method: method,
      contentType: 'application/json',
      data: JSON.stringify(formData)
    })
    .done(function(data) {
      if (data.success) {
        showToast(currentEditId ? 'Category updated successfully' : 'Category created successfully', 'success');
        closeCategoryModal();
        loadCategories();
      } else {
        showToast(data.message || 'Failed to save category', 'error');
      }
    })
    .fail(function() {
      showToast('Failed to save category', 'error');
    })
    .always(function() {
      $btn.prop('disabled', false);
      $icon.removeClass('fa-spin');
      $icon.hide();
      $span.text(currentEditId ? 'Update Category' : 'Save Category');
    });
  });
  
  $('#categoryName').on('input', function() {
    $(this).removeClass('is-invalid');
    if (!slugManuallyEdited) {
      var name = $(this).val();
      var slug = name.toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
      $('#categorySlug').val(slug);
    }
  });
  
  $('#categorySlug').on('input', function() {
    $(this).removeClass('is-invalid');
    slugManuallyEdited = true;
  });
  
  $(document).on('click', '.edit-cat-btn', function(e) {
    e.stopPropagation();
    editCategory($(this).data('id'));
  });
  
  $(document).on('click', '.view-cat-btn', function(e) {
    e.stopPropagation();
    openViewCategoryModal($(this).data('id'));
  });
  
  $(document).on('click', '.delete-cat-btn', function(e) {
    e.stopPropagation();
    deleteCategory($(this).data('id'));
  });
  
  $('#openCategoryModalBtn, #addFirstCategoryBtn').on('click', function() {
    openCategoryModal(false);
  });
  
  $('#confirmCategoryDeleteBtn').on('click', confirmDeleteCategory);
  
  $('#viewEditCategoryBtn').on('click', function() {
    if (currentViewId) {
      closeViewCategoryModal();
      editCategory(currentViewId);
    }
  });
  
  $('.modal-overlay').on('click', function(e) {
    if (e.target === this) {
      $(this).removeClass('active');
      $('body').css('overflow', '');
    }
  });
  
  $(document).on('keydown', function(e) {
    if (e.key === 'Escape') {
      $('.modal-overlay.active').removeClass('active');
      $('body').css('overflow', '');
    }
  });
  
  window.closeCategoryModal = closeCategoryModal;
  window.closeViewCategoryModal = closeViewCategoryModal;
});

function formatDate(dateString) {
  if (!dateString) return 'N/A';
  var date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}
</script>