<!-- Page Header -->
<div class="page-header">
  <div>
    <h2>Manage Users</h2>
    <p class="text-muted">View and manage all registered users</p>
  </div>
</div>

<!-- Filters -->
<div class="filters-bar">
  <div class="filter-group">
    <label>Role</label>
    <select class="filter-select" id="roleFilter">
      <option value="">All Roles</option>
      <option value="user">User</option>
      <option value="admin">Admin</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Status</label>
    <select class="filter-select" id="statusFilter">
      <option value="">All Status</option>
      <option value="active">Active</option>
      <option value="inactive">Inactive</option>
    </select>
  </div>
  <div class="filter-divider"></div>
  <div class="filter-search">
    <i class="fas fa-search"></i>
    <input type="text" placeholder="Search by name, email, phone..." id="searchInput">
  </div>
  <div class="filter-results" id="filterResults">
    <strong><%= users ? users.length : 0 %></strong> users found
  </div>
</div>

<!-- Users Table -->
<div class="table-card">
  <div id="loadingState" class="loading-state" style="display: none;">
    <div class="spinner"></div>
    <span>Loading users...</span>
  </div>
  <div class="table-responsive">
    <table class="data-table" id="usersTable">
      <thead>
        <tr>
          <th>User</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Orders</th>
          <th>Joined</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="usersTableBody">
        <% if (users && users.length > 0) { %>
          <% users.forEach(user => { %>
            <tr data-id="<%= user.id %>">
              <td>
                <div class="user-cell">
                  <img src="<%= user.avatar || '/images/default-avatar.png' %>" alt="<%= user.firstName %>" class="user-avatar-sm">
                  <div class="user-info">
                    <span class="user-name"><%= user.firstName %> <%= user.lastName %></span>
                    <span class="user-phone"><%= user.phone || 'No phone' %></span>
                  </div>
                </div>
              </td>
              <td>
                <span class="user-email"><%= user.email %></span>
              </td>
              <td>
                <span class="role-badge <%= user.role %>">
                  <%= user.role %>
                </span>
              </td>
              <td>
                <span class="status-badge <%= user.status === 'active' ? 'status-delivered' : 'status-cancelled' %>">
                  <%= user.status || 'active' %>
                </span>
              </td>
              <td>
                <span class="orders-count"><%= user.orderCount || 0 %></span>
              </td>
              <td>
                <span class="join-date"><%= new Date(user.createdAt).toLocaleDateString() %></span>
              </td>
              <td>
                <div class="action-buttons">
                  <button class="btn-icon view-user-btn" data-id="<%= user.id %>" title="View Details">
                    <i class="fas fa-eye"></i>
                  </button>
                  <button class="btn-icon edit-user-btn" data-id="<%= user.id %>" title="Edit User">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button class="btn-icon email-user-btn" data-id="<%= user.id %>" data-name="<%= user.firstName %> <%= user.lastName %>" data-email="<%= user.email %>" title="Send Email">
                    <i class="fas fa-envelope"></i>
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="no-data">No users found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- View User Modal -->
<div class="modal-overlay" id="viewUserModal">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h3><i class="fas fa-user"></i> User Profile</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body" id="viewUserBody">
      <div class="loading-state">
        <div class="spinner"></div>
        <span>Loading...</span>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Close</button>
      <button type="button" class="btn btn-primary" id="viewEditUserBtn">
        <i class="fas fa-edit"></i> Edit User
      </button>
    </div>
  </div>
</div>

<!-- Edit User Modal -->
<div class="modal-overlay" id="editUserModal">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-user-edit"></i> Edit User</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="editUserForm">
      <div class="modal-body">
        <input type="hidden" id="editUserId">
        
        <div class="user-profile-summary">
          <img src="/images/default-avatar.png" alt="User" class="profile-avatar-sm" id="editUserAvatar">
          <div class="profile-summary-info">
            <h4 id="editUserName">User Name</h4>
            <span id="editUserEmail">user@email.com</span>
          </div>
        </div>
        
        <div class="form-group">
          <label for="editUserRole">Role <span class="text-danger">*</span></label>
          <select class="form-control" id="editUserRole" name="role" required>
            <option value="user">User</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="editUserStatus">Status <span class="text-danger">*</span></label>
          <select class="form-control" id="editUserStatus" name="status" required>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="editUserPhone">Phone Number</label>
          <input type="tel" class="form-control" id="editUserPhone" name="phone" placeholder="Enter phone number">
        </div>
        
        <div class="form-group">
          <label for="editUserAddress">Address</label>
          <textarea class="form-control" id="editUserAddress" name="address" rows="3" placeholder="Enter address"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline close-modal">Cancel</button>
        <button type="submit" class="btn btn-primary" id="editUserSubmitBtn">
          <i class="fas fa-spinner fa-spin" style="display: none;"></i>
          <span>Save Changes</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Email User Modal -->
<div class="modal-overlay" id="emailUserModal">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="fas fa-envelope"></i> Send Email</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="emailUserForm">
      <div class="modal-body">
        <input type="hidden" id="emailUserId">

        <div class="user-profile-summary">
          <div class="profile-summary-info">
            <h4 id="emailUserName">User Name</h4>
            <span id="emailUserEmail">user@email.com</span>
          </div>
        </div>

        <div class="form-group">
          <label for="emailSubject">Subject <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="emailSubject" name="subject" placeholder="Enter email subject" required>
        </div>

        <div class="form-group">
          <label for="emailMessage">Message <span class="text-danger">*</span></label>
          <textarea class="form-control" id="emailMessage" name="message" rows="6" placeholder="Write your message..." required></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline close-modal">Cancel</button>
        <button type="submit" class="btn btn-primary" id="emailUserSubmitBtn">
          <i class="fas fa-spinner fa-spin" style="display: none;"></i>
          <span><i class="fas fa-paper-plane"></i> Send Email</span>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
$(document).ready(function() {
  var allUsers = [];
  var currentViewId = null;
  var currentEditId = null;
  
  function formatDate(dateString) {
    if (!dateString) return 'N/A';
    var date = new Date(dateString);
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }
  
  function debounce(func, wait) {
    var timeout;
    return function() {
      var args = arguments;
      clearTimeout(timeout);
      timeout = setTimeout(function() { func.apply(this, args); }, wait);
    };
  }
  
  function loadUsers() {
    $('#loadingState').show();
    $('#usersTableBody').hide();
    
    $.get('/admin/api/users')
      .done(function(data) {
        if (data.success) {
          allUsers = data.users;
          renderUsers(allUsers);
          updateUsersCount(allUsers.length);
        }
      })
      .fail(function() {
        showToast('Error loading users', 'error');
      })
      .always(function() {
        $('#loadingState').hide();
        $('#usersTableBody').show();
      });
  }
  
  function renderUsers(users) {
    if (users.length === 0) {
      $('#usersTableBody').html(`
        <tr>
          <td colspan="7">
            <div class="empty-state">
              <i class="fas fa-users"></i>
              <p>No users found</p>
            </div>
          </td>
        </tr>
      `);
      return;
    }
    
    var html = users.map(function(user) {
      return `
        <tr data-id="${user.id}">
          <td>
            <div class="user-cell">
              <img src="${user.avatar || '/images/default-avatar.png'}" alt="${user.firstName}" class="user-avatar-sm">
              <div class="user-info">
                <span class="user-name">${user.firstName} ${user.lastName || ''}</span>
                <span class="user-phone">${user.phone || 'No phone'}</span>
              </div>
            </div>
          </td>
          <td><span class="user-email">${user.email}</span></td>
          <td><span class="role-badge ${user.role}">${user.role}</span></td>
          <td><span class="status-badge ${user.status === 'active' ? 'status-delivered' : 'status-cancelled'}">${user.status || 'active'}</span></td>
          <td><span class="orders-count">${user.orderCount || 0}</span></td>
          <td><span class="join-date">${formatDate(user.createdAt)}</span></td>
          <td>
            <div class="action-buttons">
              <button class="btn-icon view-user-btn" data-id="${user.id}" title="View Details">
                <i class="fas fa-eye"></i>
              </button>
              <button class="btn-icon edit-user-btn" data-id="${user.id}" title="Edit User">
                <i class="fas fa-edit"></i>
              </button>
              <button class="btn-icon email-user-btn" data-id="${user.id}" data-name="${user.firstName} ${user.lastName || ''}" data-email="${user.email}" title="Send Email">
                <i class="fas fa-envelope"></i>
              </button>
            </div>
          </td>
        </tr>
      `;
    }).join('');
    
    $('#usersTableBody').html(html);
  }
  
  function updateUsersCount(count) {
    $('#filterResults').html('<strong>' + count + '</strong> user' + (count !== 1 ? 's' : '') + ' found');
  }
  
  function filterUsers() {
    var role = $('#roleFilter').val();
    var status = $('#statusFilter').val();
    var search = $('#searchInput').val().toLowerCase();
    
    var filtered = allUsers;
    
    if (role) {
      filtered = filtered.filter(function(u) { return u.role === role; });
    }
    
    if (status) {
      filtered = filtered.filter(function(u) { return u.status === status; });
    }
    
    if (search) {
      filtered = filtered.filter(function(u) {
        return (u.firstName + ' ' + (u.lastName || '')).toLowerCase().includes(search) ||
               u.email.toLowerCase().includes(search) ||
               (u.phone && u.phone.includes(search));
      });
    }
    
    renderUsers(filtered);
    updateUsersCount(filtered.length);
  }
  
  function openViewUserModal(id) {
    currentViewId = id;
    var user = allUsers.find(function(u) { return u.id === id; });
    
    if (!user) {
      showToast('User not found', 'error');
      return;
    }
    
    $('#viewUserModal').addClass('active');
    $('body').css('overflow', 'hidden');
    $('#viewUserBody').html('<div class="loading-state"><div class="spinner"></div><span>Loading...</span></div>');
    
    $.get('/admin/api/users/' + id)
      .done(function(data) {
        if (data.success) {
          var u = data.user;
          var html = `
            <div class="view-user-profile">
              <div class="profile-header-card">
                <img src="${u.avatar || '/images/default-avatar.png'}" alt="${u.firstName}" class="profile-avatar-lg">
                <div class="profile-header-info">
                  <h3>${u.firstName} ${u.lastName || ''}</h3>
                  <p class="user-email">${u.email}</p>
                  <div class="profile-badges">
                    <span class="role-badge ${u.role}">${u.role}</span>
                    <span class="status-badge ${u.status === 'active' ? 'status-delivered' : 'status-cancelled'}">${u.status || 'active'}</span>
                  </div>
                </div>
              </div>
              
              <div class="profile-stats-grid">
                <div class="stat-box">
                  <i class="fas fa-shopping-bag"></i>
                  <div class="stat-value">${u.orderCount || 0}</div>
                  <div class="stat-label">Total Orders</div>
                </div>
                <div class="stat-box">
                  <i class="fas fa-dollar-sign"></i>
                  <div class="stat-value">₦${(u.totalSpent || 0).toFixed(2)}</div>
                  <div class="stat-label">Total Spent</div>
                </div>
              </div>
              
              <div class="profile-details-section">
                <h4><i class="fas fa-info-circle"></i> Personal Information</h4>
                <div class="detail-grid">
                  <div class="detail-item">
                    <span class="detail-icon"><i class="fas fa-phone"></i></span>
                    <div class="detail-content">
                      <span class="detail-label">Phone</span>
                      <span class="detail-value">${u.phone || 'Not provided'}</span>
                    </div>
                  </div>
                  <div class="detail-item">
                    <span class="detail-icon"><i class="fas fa-calendar-alt"></i></span>
                    <div class="detail-content">
                      <span class="detail-label">Member Since</span>
                      <span class="detail-value">${formatDate(u.createdAt)}</span>
                    </div>
                  </div>
                  ${u.address ? `
                  <div class="detail-item">
                    <span class="detail-icon"><i class="fas fa-map-marker-alt"></i></span>
                    <div class="detail-content">
                      <span class="detail-label">Address</span>
                      <span class="detail-value">${u.address}</span>
                    </div>
                  </div>
                  ` : ''}
                </div>
              </div>
              
              <div class="profile-orders-section">
                <h4><i class="fas fa-box"></i> Recent Orders</h4>
                <div class="orders-list" id="userOrdersList">
                  <div class="loading-state">
                    <div class="spinner"></div>
                    <span>Loading orders...</span>
                  </div>
                </div>
              </div>
            </div>
          `;
          
          $('#viewUserBody').html(html);
          
          $.get('/admin/api/orders?userId=' + id)
            .done(function(orderData) {
              if (orderData.success && orderData.orders && orderData.orders.length > 0) {
                var ordersHtml = orderData.orders.slice(0, 5).map(function(order) {
                  return `
                    <div class="order-item-summary">
                      <div class="order-summary-left">
                        <span class="order-num">#${order.orderNumber}</span>
                        <span class="order-date">${formatDate(order.createdAt)}</span>
                      </div>
                      <div class="order-summary-right">
                        <span class="order-amount">₦${order.total.toFixed(2)}</span>
                        <span class="status-badge status-${order.status}">${order.status}</span>
                      </div>
                    </div>
                  `;
                }).join('');
                $('#userOrdersList').html(ordersHtml);
              } else {
                $('#userOrdersList').html('<p class="text-muted">No orders found</p>');
              }
            })
            .fail(function() {
              $('#userOrdersList').html('<p class="text-muted">Failed to load orders</p>');
            });
        }
      })
      .fail(function() {
        $('#viewUserBody').html('<div class="alert alert-danger">Failed to load user details</div>');
      });
  }
  
  function closeViewUserModal() {
    $('#viewUserModal').removeClass('active');
    $('body').css('overflow', '');
    currentViewId = null;
  }
  
  function openEditUserModal(id) {
    currentEditId = id;
    var user = allUsers.find(function(u) { return u.id === id; });
    
    if (!user) {
      showToast('User not found', 'error');
      return;
    }
    
    $('#editUserId').val(user.id);
    $('#editUserAvatar').attr('src', user.avatar || '/images/default-avatar.png');
    $('#editUserName').text(user.firstName + ' ' + (user.lastName || ''));
    $('#editUserEmail').text(user.email);
    $('#editUserRole').val(user.role);
    $('#editUserStatus').val(user.status || 'active');
    $('#editUserPhone').val(user.phone || '');
    $('#editUserAddress').val(user.address || '');
    
    $('#editUserModal').addClass('active');
    $('body').css('overflow', 'hidden');
  }
  
  function closeEditUserModal() {
    $('#editUserModal').removeClass('active');
    $('body').css('overflow', '');
    currentEditId = null;
  }
  
  $('#editUserForm').on('submit', function(e) {
    e.preventDefault();
    
    var formData = {
      role: $('#editUserRole').val(),
      status: $('#editUserStatus').val(),
      phone: $('#editUserPhone').val(),
      address: $('#editUserAddress').val()
    };
    
    var $btn = $('#editUserSubmitBtn');
    var $icon = $btn.find('i');
    var $span = $btn.find('span');
    
    $btn.prop('disabled', true);
    $icon.addClass('fa-spin');
    $icon.show();
    $span.text('Saving...');
    
    $.ajax({
      url: '/admin/api/users/' + currentEditId,
      method: 'PUT',
      contentType: 'application/json',
      data: JSON.stringify(formData)
    })
    .done(function(data) {
      if (data.success) {
        showToast('User updated successfully', 'success');
        closeEditUserModal();
        loadUsers();
      } else {
        showToast(data.message || 'Failed to update user', 'error');
      }
    })
    .fail(function() {
      showToast('Failed to update user', 'error');
    })
    .always(function() {
      $btn.prop('disabled', false);
      $icon.removeClass('fa-spin');
      $icon.hide();
      $span.text('Save Changes');
    });
  });
  
  // Email User
  function openEmailUserModal(id) {
    var user = allUsers.find(function(u) { return u.id === id; });
    if (!user) {
      showToast('User not found', 'error');
      return;
    }
    $('#emailUserId').val(user.id);
    $('#emailUserName').text(user.firstName + ' ' + (user.lastName || ''));
    $('#emailUserEmail').text(user.email);
    $('#emailSubject').val('');
    $('#emailMessage').val('');
    $('#emailUserModal').addClass('active');
    $('body').css('overflow', 'hidden');
  }
  
  function closeEmailUserModal() {
    $('#emailUserModal').removeClass('active');
    $('body').css('overflow', '');
  }
  
  $(document).on('click', '.email-user-btn', function(e) {
    e.stopPropagation();
    openEmailUserModal($(this).data('id'));
  });
  
  $('#emailUserForm').on('submit', function(e) {
    e.preventDefault();
    var userId = $('#emailUserId').val();
    var subject = $('#emailSubject').val().trim();
    var message = $('#emailMessage').val().trim();
    if (!subject || !message) {
      showToast('Subject and message are required', 'error');
      return;
    }
    var $btn = $('#emailUserSubmitBtn');
    var $icon = $btn.find('i.fa-spinner');
    var $span = $btn.find('span');
    $btn.prop('disabled', true);
    $icon.show();
    $span.text('Sending...');
    $.ajax({
      url: '/admin/api/users/' + userId + '/email',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify({ subject: subject, message: message })
    })
    .done(function(data) {
      if (data.success) {
        showToast('Email sent successfully', 'success');
        closeEmailUserModal();
      } else {
        showToast(data.message || 'Failed to send email', 'error');
      }
    })
    .fail(function() {
      showToast('Failed to send email', 'error');
    })
    .always(function() {
      $btn.prop('disabled', false);
      $icon.hide();
      $span.html('<i class="fas fa-paper-plane"></i> Send Email');
    });
  });
  
  $('#roleFilter, #statusFilter').on('change', filterUsers);
  $('#searchInput').on('input', debounce(filterUsers, 300));
  
  $(document).on('click', '.view-user-btn', function(e) {
    e.stopPropagation();
    openViewUserModal($(this).data('id'));
  });
  
  $(document).on('click', '.edit-user-btn', function(e) {
    e.stopPropagation();
    openEditUserModal($(this).data('id'));
  });
  
  $('#viewEditUserBtn').on('click', function() {
    if (currentViewId) {
      closeViewUserModal();
      openEditUserModal(currentViewId);
    }
  });
  
  $('.modal-overlay').on('click', function(e) {
    if (e.target === this) {
      $(this).removeClass('active');
      $('body').css('overflow', '');
    }
  });
  
  $(document).on('keydown', function(e) {
    if (e.key === 'Escape') {
      $('.modal-overlay.active').removeClass('active');
      $('body').css('overflow', '');
    }
  });
  
  loadUsers();
});
</script>