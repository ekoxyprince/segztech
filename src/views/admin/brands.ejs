<!-- Page Header -->
<div class="page-header">
  <div>
    <h2>Manage Brands</h2>
    <p class="text-muted">Manage product brands and their categories</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" id="openBrandModalBtn">
      <i class="fas fa-plus"></i> Add Brand
    </button>
  </div>
</div>

<!-- Brands Grid -->
<div class="brands-grid" id="brandsGrid">
  <div id="loadingState" class="loading-state" style="display: none; grid-column: 1 / -1;">
    <div class="spinner"></div>
    <span>Loading brands...</span>
  </div>
  <% if (brands && brands.length > 0) { %>
    <% brands.forEach(brand => { %>
      <div class="brand-card" data-id="<%= brand.id %>">
        <div class="brand-logo">
          <% if (brand.logo) { %>
            <img src="<%= brand.logo %>" alt="<%= brand.name %>">
          <% } else { %>
            <i class="fas fa-tag"></i>
          <% } %>
        </div>
        <div class="brand-details">
          <h4><%= brand.name %></h4>
          <% if (brand.categories && brand.categories.length > 0) { %>
            <p class="brand-categories">
              <%= brand.categories.slice(0, 3).map(c => c.name).join(', ') %>
              <% if (brand.categories.length > 3) { %>
                +<%= brand.categories.length - 3 %> more
              <% } %>
            </p>
          <% } else { %>
            <p class="brand-categories text-muted">No categories</p>
          <% } %>
        </div>
        <div class="brand-actions">
          <button class="btn-icon edit-brand-btn" data-id="<%= brand.id %>" title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button class="btn-icon btn-delete delete-brand-btn" data-id="<%= brand.id %>" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="no-brands">
      <i class="fas fa-tags"></i>
      <p>No brands found</p>
      <button class="btn btn-primary" id="addFirstBrandBtn">Add First Brand</button>
    </div>
  <% } %>
</div>

<!-- Brand Add/Edit Modal -->
<div class="modal-overlay" id="brandModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="brandModalTitle"><i class="fas fa-plus"></i> Add Brand</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <form id="brandForm">
      <div class="modal-body">
        <div class="form-group">
          <label for="brandName">Brand Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="brandName" name="name" placeholder="e.g., Apple" required>
          <div class="invalid-feedback" id="brandNameError"></div>
        </div>
        <div class="form-group">
          <label for="brandLogo">Logo URL</label>
          <input type="url" class="form-control" id="brandLogo" name="logo" placeholder="https://example.com/logo.png">
          <small class="form-text text-muted">URL to brand logo image</small>
        </div>
        <div class="form-group">
          <label for="brandWebsite">Website</label>
          <input type="url" class="form-control" id="brandWebsite" name="website" placeholder="https://example.com">
          <small class="form-text text-muted">Official brand website</small>
        </div>
        <div class="form-group">
          <label>Categories <span class="text-danger">*</span></label>
          <div class="category-checkboxes" id="categoryCheckboxes">
            <% if (categories && categories.length > 0) { %>
              <% categories.forEach(category => { %>
                <div class="checkbox-item">
                  <input type="checkbox" id="category_<%= category.slug %>" name="categories" value="<%= category.slug %>">
                  <label for="category_<%= category.slug %>"><%= category.name %></label>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-muted">No categories available. <a href="/admin/categories">Create categories first</a>.</p>
            <% } %>
          </div>
          <div class="invalid-feedback" id="brandCategoriesError"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline close-modal">Cancel</button>
        <button type="submit" class="btn btn-primary" id="brandSubmitBtn">
          <i class="fas fa-spinner fa-spin" style="display: none;"></i>
          <span>Save Brand</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteBrandModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h3><i class="fas fa-exclamation-triangle"></i> Confirm Delete</h3>
      <button type="button" class="modal-close close-modal">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to delete this brand? Products using this brand will need to be reassigned.</p>
      <input type="hidden" id="deleteBrandId">
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline close-modal">Cancel</button>
      <button type="button" class="btn btn-danger" id="confirmBrandDeleteBtn">
        <i class="fas fa-spinner fa-spin" style="display: none;"></i>
        <span>Delete</span>
      </button>
    </div>
  </div>
</div>

<script>
$(document).ready(function() {
  var currentEditId = null;
  
  loadBrands();
  
  function openBrandModal(isEdit) {
    currentEditId = isEdit || null;
    
    $('#brandModal').addClass('active');
    $('body').css('overflow', 'hidden');
    
    if (isEdit) {
      $('#brandModalTitle').html('<i class="fas fa-edit"></i> Edit Brand');
      $('#brandSubmitBtn').find('span').text('Update Brand');
    } else {
      $('#brandModalTitle').html('<i class="fas fa-plus"></i> Add Brand');
      $('#brandSubmitBtn').find('span').text('Save Brand');
    }
    
    $('#brandForm')[0].reset();
    $('#brandForm').find('.is-invalid').removeClass('is-invalid');
  }
  
  function closeBrandModal() {
    $('#brandModal').removeClass('active');
    $('body').css('overflow', '');
    currentEditId = null;
  }
  
  function editBrand(id) {
    currentEditId = id;
    $('#brandModal').addClass('active');
    $('body').css('overflow', 'hidden');
    $('#brandModalTitle').html('<i class="fas fa-edit"></i> Edit Brand');
    $('#brandSubmitBtn').find('span').text('Update Brand');
    
    $.get('/admin/api/brands/' + id)
      .done(function(data) {
        if (data.success) {
          $('#brandName').val(data.brand.name);
          $('#brandLogo').val(data.brand.logo || '');
          $('#brandWebsite').val(data.brand.website || '');
          
          $('#categoryCheckboxes').find('input[type="checkbox"]').prop('checked', false);
          if (data.brand.categories) {
            data.brand.categories.forEach(function(catId) {
              $('#category_' + catId).prop('checked', true);
            });
          }
        }
      })
      .fail(function() {
        showToast('Failed to load brand', 'error');
        closeBrandModal();
      });
  }
  
  function deleteBrand(id) {
    $('#deleteBrandId').val(id);
    $('#deleteBrandModal').addClass('active');
    $('body').css('overflow', 'hidden');
  }
  
  function confirmDeleteBrand() {
    var id = $('#deleteBrandId').val();
    var $btn = $('#confirmBrandDeleteBtn');
    var $icon = $btn.find('i');
    var $span = $btn.find('span');
    
    $btn.prop('disabled', true);
    $icon.addClass('fa-spin');
    $icon.show();
    $span.text('Deleting...');
    
    $.ajax({
      url: '/admin/api/brands/' + id,
      method: 'DELETE'
    })
    .done(function(data) {
      if (data.success) {
        showToast('Brand deleted successfully', 'success');
        $('#deleteBrandModal').removeClass('active');
        $('body').css('overflow', '');
        loadBrands();
      }
    })
    .fail(function() {
      showToast('Failed to delete brand', 'error');
    })
    .always(function() {
      $btn.prop('disabled', false);
      $icon.removeClass('fa-spin');
      $icon.hide();
      $span.text('Delete');
    });
  }
  
  function loadBrands() {
    $('#loadingState').show();
    $('.brand-card, .no-brands').hide();
    
    $.get('/admin/api/brands')
      .done(function(data) {
        $('#loadingState').hide();
        
        if (!data.brands || data.brands.length === 0) {
          $('#brandsGrid').html(`
            <div class="no-brands">
              <i class="fas fa-tags"></i>
              <p>No brands found</p>
              <button class="btn btn-primary" id="addFirstBrandBtn">Add First Brand</button>
            </div>
          `);
          return;
        }
        
        var html = data.brands.map(function(brand) {
          var logoHtml = brand.logo 
            ? '<img src="' + brand.logo + '" alt="' + brand.name + '">' 
            : '<i class="fas fa-tag"></i>';
          
          var categoriesHtml = '';
          if (brand.categories && brand.categories.length > 0) {
            var catNames = brand.categories.slice(0, 3).map(function(c) { return c.name; }).join(', ');
            categoriesHtml = '<p class="brand-categories">' + catNames;
            if (brand.categories.length > 3) {
              categoriesHtml += ' +' + (brand.categories.length - 3) + ' more';
            }
            categoriesHtml += '</p>';
          } else {
            categoriesHtml = '<p class="brand-categories text-muted">No categories</p>';
          }
          
          return `
            <div class="brand-card" data-id="${brand.id}">
              <div class="brand-logo">${logoHtml}</div>
              <div class="brand-details">
                <h4>${brand.name}</h4>
                ${categoriesHtml}
              </div>
              <div class="brand-actions">
                <button class="btn-icon edit-brand-btn" data-id="${brand.id}" title="Edit">
                  <i class="fas fa-edit"></i>
                </button>
                <button class="btn-icon btn-delete delete-brand-btn" data-id="${brand.id}" title="Delete">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
          `;
        }).join('');
        
        $('#brandsGrid').html(html);
      })
      .fail(function() {
        $('#loadingState').hide();
        showToast('Failed to load brands', 'error');
      });
  }
  
  $('#brandForm').on('submit', function(e) {
    e.preventDefault();
    
    var name = $('#brandName').val().trim();
    var logo = $('#brandLogo').val().trim();
    var website = $('#brandWebsite').val().trim();
    var selectedCategories = [];
    $('#categoryCheckboxes').find('input[type="checkbox"]:checked').each(function() {
      selectedCategories.push($(this).val());
    });
    
    if (!name) {
      $('#brandName').addClass('is-invalid');
      return;
    }
    
    if (selectedCategories.length === 0) {
      $('#categoryCheckboxes').addClass('is-invalid');
      showToast('Please select at least one category', 'error');
      return;
    }
    
    var formData = {
      name: name,
      logo: logo,
      website: website,
      categories: selectedCategories
    };
    
    var url = currentEditId ? '/admin/api/brands/' + currentEditId : '/admin/api/brands';
    var method = currentEditId ? 'PUT' : 'POST';
    
    var $btn = $('#brandSubmitBtn');
    var $icon = $btn.find('i');
    var $span = $btn.find('span');
    
    $btn.prop('disabled', true);
    $icon.addClass('fa-spin');
    $icon.show();
    $span.text(currentEditId ? 'Updating...' : 'Saving...');
    
    $.ajax({
      url: url,
      method: method,
      contentType: 'application/json',
      data: JSON.stringify(formData)
    })
    .done(function(data) {
      if (data.success) {
        showToast(currentEditId ? 'Brand updated successfully' : 'Brand created successfully', 'success');
        closeBrandModal();
        loadBrands();
      } else {
        showToast(data.message || 'Failed to save brand', 'error');
      }
    })
    .fail(function() {
      showToast('Failed to save brand', 'error');
    })
    .always(function() {
      $btn.prop('disabled', false);
      $icon.removeClass('fa-spin');
      $icon.hide();
      $span.text(currentEditId ? 'Update Brand' : 'Save Brand');
    });
  });
  
  $('#brandName').on('input', function() {
    $(this).removeClass('is-invalid');
  });
  
  $('#categoryCheckboxes').on('change', 'input[type="checkbox"]', function() {
    $('#categoryCheckboxes').removeClass('is-invalid');
  });
  
  $(document).on('click', '.edit-brand-btn', function(e) {
    e.stopPropagation();
    editBrand($(this).data('id'));
  });
  
  $(document).on('click', '.delete-brand-btn', function(e) {
    e.stopPropagation();
    deleteBrand($(this).data('id'));
  });
  
  $('#openBrandModalBtn, #addFirstBrandBtn').on('click', function() {
    openBrandModal(false);
  });
  
  $('#confirmBrandDeleteBtn').on('click', confirmDeleteBrand);
  
  $('.modal-overlay').on('click', function(e) {
    if (e.target === this) {
      $(this).removeClass('active');
      $('body').css('overflow', '');
    }
  });
  
  $(document).on('keydown', function(e) {
    if (e.key === 'Escape') {
      $('.modal-overlay.active').removeClass('active');
      $('body').css('overflow', '');
    }
  });
  
  window.closeBrandModal = closeBrandModal;
});
</script>