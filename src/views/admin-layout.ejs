<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= siteSettings.site_name %> Admin</title>
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- jQuery (loaded first) -->
  <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  
  <!-- Admin CSS -->
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-responsive.css">
</head>
<body>
  <!-- Admin Wrapper -->
  <div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-header">
<a href="/admin/dashboard" class="sidebar-logo">
  <img src="/images/segztech.png" alt="SegzTech">
</a>
        <button class="sidebar-close" id="sidebarClose">
          <i class="fas fa-times"></i>
        </button>
      </div>
      
      <div class="sidebar-user">
        <img src="<%= user.avatar %>" alt="<%= user.firstName %>" class="user-avatar">
        <div class="user-info">
          <span class="user-name"><%= user.firstName %> <%= user.lastName %></span>
          <span class="user-role">
            <i class="fas fa-shield-alt"></i> Administrator
          </span>
        </div>
      </div>
      
      <nav class="sidebar-nav">
        <div class="nav-group">
          <span class="nav-group-title">Main</span>
          <a href="/admin/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
            <i class="nav-icon fas fa-chart-line"></i>
            <span class="nav-text">Dashboard</span>
          </a>
          <a href="/admin/analytics" class="nav-item <%= page === 'analytics' ? 'active' : '' %>">
            <i class="nav-icon fas fa-chart-pie"></i>
            <span class="nav-text">Analytics</span>
          </a>
        </div>
        
        <div class="nav-group">
          <span class="nav-group-title">Management</span>
          <a href="/admin/products" class="nav-item <%= page === 'products' ? 'active' : '' %>">
            <i class="nav-icon fas fa-box"></i>
            <span class="nav-text">Products</span>
          </a>
          <a href="/admin/orders" class="nav-item <%= page === 'orders' ? 'active' : '' %>">
            <i class="nav-icon fas fa-shopping-bag"></i>
            <span class="nav-text">Orders</span>
          </a>
          <a href="/admin/users" class="nav-item <%= page === 'users' ? 'active' : '' %>">
            <i class="nav-icon fas fa-users"></i>
            <span class="nav-text">Users</span>
          </a>
          <a href="/admin/categories" class="nav-item <%= page === 'categories' ? 'active' : '' %>">
            <i class="nav-icon fas fa-tags"></i>
            <span class="nav-text">Categories</span>
          </a>
          <a href="/admin/flash-sales" class="nav-item <%= page === 'flash-sales' ? 'active' : '' %>">
            <i class="nav-icon fas fa-bolt"></i>
            <span class="nav-text">Flash Sales</span>
          </a>
          <a href="/admin/hierarchy" class="nav-item <%= page === 'hierarchy' ? 'active' : '' %>">
            <i class="nav-icon fas fa-sitemap"></i>
            <span class="nav-text">Hierarchy</span>
          </a>
        </div>
        
        <div class="nav-group">
          <span class="nav-group-title">Communication</span>
          <a href="/admin/notifications" class="nav-item <%= page === 'notifications' ? 'active' : '' %>">
            <i class="nav-icon fas fa-bell"></i>
            <span class="nav-text">Notifications</span>
          </a>
          <a href="/admin/messages" class="nav-item <%= page === 'messages' ? 'active' : '' %>">
            <i class="nav-icon fas fa-envelope"></i>
            <span class="nav-text">Messages</span>
          </a>
        </div>
        
        <div class="nav-group">
          <span class="nav-group-title">Settings</span>
          <a href="/admin/settings" class="nav-item <%= page === 'settings' ? 'active' : '' %>">
            <i class="nav-icon fas fa-cog"></i>
            <span class="nav-text">Settings</span>
          </a>
          <a href="/admin/password" class="nav-item <%= page === 'settings' ? 'active' : '' %>">
            <i class="nav-icon fas fa-key"></i>
            <span class="nav-text">Password</span>
          </a>
        </div>
      </nav>
      
      <div class="sidebar-footer">
        <a href="/" target="_blank" class="nav-item">
          <i class="nav-icon fas fa-external-link-alt"></i>
          <span class="nav-text">View Store</span>
        </a>
        <a href="/admin/logout" class="nav-item logout">
          <i class="nav-icon fas fa-sign-out-alt"></i>
          <span class="nav-text">Logout</span>
        </a>
      </div>
    </aside>
    
    <!-- Mobile Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    
    <!-- Main Content -->
    <div class="admin-main">
      <!-- Top Bar -->
      <header class="admin-topbar">
        <div class="topbar-left">
          <button class="menu-toggle" id="menuToggle">
            <i class="fas fa-bars"></i>
          </button>
          <div class="page-info">
            <h1 class="page-title"><%= title %></h1>
            <nav class="breadcrumb">
              <a href="/admin/dashboard">Home</a>
              <i class="fas fa-chevron-right"></i>
              <span><%= title %></span>
            </nav>
          </div>
        </div>
        
        <div class="topbar-right">
          <div class="topbar-search">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search anything...">
          </div>
          
          <div class="topbar-actions">
            <a href="/admin/notifications" class="action-btn" title="Notifications">
              <i class="fas fa-bell"></i>
              <span class="action-badge" id="notificationBadge" style="display: none;">0</span>
            </a>
            <a href="/admin/messages" class="action-btn" title="Messages">
              <i class="fas fa-envelope"></i>
              <span class="action-badge" id="messageBadge" style="display: none;">0</span>
            </a>
          </div>
          
          <div class="topbar-user">
            <a href="/admin/logout" class="quick-btn">
              <i class="fas fa-sign-out-alt"></i>
              <span>Logout</span>
            </a>
          </div>
        </div>
      </header>
      
      <!-- Page Content -->
      <main class="admin-content">
        <%- body %>
      </main>
      
      <!-- Footer -->
      <footer class="admin-footer">
        <div class="footer-content">
          <p>&copy; <%= new Date().getFullYear() %> <%= siteSettings.site_name %> Admin. All rights reserved.</p>
          <div class="footer-links">
            <a href="/">View Store</a>
            <a href="/admin/dashboard">Dashboard</a>
            <a href="/admin/settings">Settings</a>
          </div>
        </div>
      </footer>
    </div>
  </div>
  

  
  <!-- Admin JS -->
  <script src="/js/admin.js"></script>
  <script>
    (function() {
      fetch('/admin/api/notification-count')
        .then(r => r.json())
        .then(data => {
          var nb = document.getElementById('notificationBadge');
          var mb = document.getElementById('messageBadge');
          if (nb && data.unreadNotifications > 0) {
            nb.style.display = 'inline';
            nb.textContent = data.unreadNotifications > 99 ? '99+' : data.unreadNotifications;
          }
          if (mb && data.unreadMessages > 0) {
            mb.style.display = 'inline';
            mb.textContent = data.unreadMessages > 99 ? '99+' : data.unreadMessages;
          }
        })
        .catch(() => {});
    })();
  </script>
</body>
</html>
