<%- include('../partials/header') %>

<main class="main-content">
  <!-- Checkout Header -->
  <section class="checkout-header">
    <div class="container">
      <div class="checkout-header-content">
        <a href="/cart" class="checkout-back">
          <i class="fas fa-arrow-left"></i> Back to Cart
        </a>
        <div class="checkout-logo">
          <img src="/images/segztech.png" alt="SegzTech">
        </div>
        <div class="checkout-secure">
          <i class="fas fa-shield-alt"></i> Secure Checkout
        </div>
      </div>
      
      <!-- Progress Steps -->
      <div class="checkout-progress">
        <div class="progress-step active">
          <div class="step-icon"><i class="fas fa-map-marker-alt"></i></div>
          <span class="step-label">Shipping</span>
        </div>
        <div class="progress-line"></div>
        <div class="progress-step">
          <div class="step-icon"><i class="fas fa-truck"></i></div>
          <span class="step-label">Delivery</span>
        </div>
        <div class="progress-line"></div>
        <div class="progress-step">
          <div class="step-icon"><i class="fas fa-credit-card"></i></div>
          <span class="step-label">Payment</span>
        </div>
        <div class="progress-line"></div>
        <div class="progress-step">
          <div class="step-icon"><i class="fas fa-check"></i></div>
          <span class="step-label">Complete</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Checkout Content -->
  <section class="checkout-page">
    <div class="container">
      <form action="/orders/checkout" method="POST" class="checkout-form" id="checkoutForm" novalidate>
        <div class="checkout-layout">
          <!-- Left Column - Form -->
          <div class="checkout-main">
            <% if (error) { %>
              <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i>
                <%= error %>
              </div>
            <% } %>
            
            <!-- Shipping Address -->
            <div class="checkout-card" id="shippingSection">
              <div class="checkout-card-header">
                <div class="checkout-card-title">
                  <span class="checkout-card-number">1</span>
                  <h2>Shipping Address</h2>
                </div>
              </div>
              <div class="checkout-card-body">
                <% if (addresses && addresses.length > 0) { %>
                  <div class="saved-addresses" id="savedAddresses">
                    <% addresses.forEach((address, idx) => { %>
                      <label class="saved-address <%= address.isDefault ? 'selected' : '' %>">
                        <input type="radio" name="shippingAddressId" value="<%= address.id %>" <%= address.isDefault ? 'checked' : '' %>>
                        <div class="address-icon">
                          <i class="fas fa-<%= address.label && address.label.toLowerCase() === 'home' ? 'home' : 'building' %>"></i>
                        </div>
                        <div class="address-details">
                          <div class="address-header">
                            <span class="address-label"><%= address.label %></span>
                            <% if (address.isDefault) { %>
                              <span class="default-tag">Default</span>
                            <% } %>
                          </div>
                          <p class="address-name"><%= address.fullName %></p>
                          <p class="address-street"><%= address.street %></p>
                          <p class="address-city"><%= address.city %>, <%= address.state %> <%= address.zipCode %></p>
                          <p class="address-phone"><i class="fas fa-phone"></i> <%= address.phone %></p>
                        </div>
                      </label>
                    <% }) %>
                  </div>
                  <button type="button" class="btn-text" id="toggleAddressBtn" onclick="toggleNewAddress()">
                    <i class="fas fa-plus-circle"></i> Add New Address
                  </button>
                <% } %>
                
                <div class="new-address-form" id="newAddressForm" style="<%= !addresses || addresses.length === 0 ? '' : 'display: none;' %>">
                  <div class="form-row">
                    <div class="form-group">
                      <label for="fullName"><i class="fas fa-user"></i> Full Name</label>
                      <input type="text" id="fullName" name="fullName" placeholder="John Doe" class="new-address-field">
                    </div>
                    <div class="form-group">
                      <label for="phone"><i class="fas fa-phone"></i> Phone Number</label>
                      <input type="tel" id="phone" name="phone" placeholder="+1 (555) 123-4567" class="new-address-field">
                    </div>
                  </div>
                  
                  <div class="form-group">
                    <label for="street"><i class="fas fa-map-marker-alt"></i> Street Address</label>
                    <input type="text" id="street" name="street" placeholder="123 Main Street, Apt 4B" class="new-address-field">
                  </div>
                  
                  <div class="form-row">
                    <div class="form-group">
                      <label for="city"><i class="fas fa-city"></i> City</label>
                      <input type="text" id="city" name="city" placeholder="New York" class="new-address-field">
                    </div>
                    <div class="form-group">
                      <label for="state"><i class="fas fa-map"></i> State/Province</label>
                      <input type="text" id="state" name="state" placeholder="NY" class="new-address-field">
                    </div>
                  </div>
                  
                  <div class="form-row">
                    <div class="form-group">
                      <label for="zipCode"><i class="fas fa-envelope"></i> ZIP/Postal Code</label>
                      <input type="text" id="zipCode" name="zipCode" placeholder="10001" class="new-address-field">
                    </div>
                    <div class="form-group">
                      <label for="country"><i class="fas fa-globe"></i> Country</label>
                      <select id="country" name="country" class="new-address-field">
                        <option value="United States">United States</option>
                        <option value="Canada">Canada</option>
                        <option value="United Kingdom">United Kingdom</option>
                        <option value="Australia">Australia</option>
                        <option value="Germany">Germany</option>
                        <option value="France">France</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Shipping Method -->
            <div class="checkout-card" id="shippingMethodSection">
              <div class="checkout-card-header">
                <div class="checkout-card-title">
                  <span class="checkout-card-number">2</span>
                  <h2>Shipping Method</h2>
                </div>
              </div>
              <div class="checkout-card-body">
                <div class="shipping-options">
                  <label class="shipping-option selected">
                    <input type="radio" name="shippingMethod" value="standard" checked>
                    <div class="shipping-icon">
                      <i class="fas fa-truck"></i>
                    </div>
                    <div class="shipping-info">
                      <strong>Standard Shipping</strong>
                      <span>5-7 business days</span>
                    </div>
                    <div class="shipping-price">
                      <%= totals.subtotal >= 100 ? 'FREE' : '₦9,999' %>
                    </div>
                  </label>
                  
                  <label class="shipping-option">
                    <input type="radio" name="shippingMethod" value="express">
                    <div class="shipping-icon">
                      <i class="fas fa-shipping-fast"></i>
                    </div>
                    <div class="shipping-info">
                      <strong>Express Shipping</strong>
                      <span>2-3 business days</span>
                    </div>
                    <div class="shipping-price">₦19,999</div>
                  </label>
                  
                  <label class="shipping-option">
                    <input type="radio" name="shippingMethod" value="overnight">
                    <div class="shipping-icon">
                      <i class="fas fa-bolt"></i>
                    </div>
                    <div class="shipping-info">
                      <strong>Overnight Shipping</strong>
                      <span>Next business day</span>
                    </div>
                    <div class="shipping-price">₦39,999</div>
                  </label>
                </div>
              </div>
            </div>
            
            <!-- Payment Method -->
            <div class="checkout-card" id="paymentSection">
              <div class="checkout-card-header">
                <div class="checkout-card-title">
                  <span class="checkout-card-number">3</span>
                  <h2>Payment Method</h2>
                </div>
                <div class="payment-icons">
                  <i class="fab fa-cc-visa"></i>
                  <i class="fab fa-cc-mastercard"></i>
                  <i class="fab fa-cc-amex"></i>
                  <i class="fab fa-cc-paypal"></i>
                </div>
              </div>
              <div class="checkout-card-body">
                <div class="payment-methods">
                  <label class="payment-method selected">
                    <input type="radio" name="paymentMethod" value="cod" checked>
                    <div class="payment-method-icon">
                      <i class="fas fa-money-bill-wave"></i>
                    </div>
                    <div class="payment-method-info">
                      <strong>Cash on Delivery</strong>
                      <span>Pay when you receive</span>
                    </div>
                  </label>
                  
                  <label class="payment-method">
                    <input type="radio" name="paymentMethod" value="whatsapp">
                    <div class="payment-method-icon">
                      <i class="fab fa-whatsapp"></i>
                    </div>
                    <div class="payment-method-info">
                      <strong>WhatsApp Order</strong>
                      <span>Confirm via WhatsApp</span>
                    </div>
                  </label>
                </div>
              </div>
            </div>
            
            <!-- Order Notes -->
            <div class="checkout-card">
              <div class="checkout-card-header">
                <div class="checkout-card-title">
                  <span class="checkout-card-number">4</span>
                  <h2>Order Notes (Optional)</h2>
                </div>
              </div>
              <div class="checkout-card-body">
                <textarea name="notes" class="notes-textarea" placeholder="Add any special instructions for your order..."></textarea>
              </div>
            </div>
          </div>
          
          <!-- Right Column - Order Summary -->
          <div class="checkout-sidebar">
            <div class="order-summary-card">
              <div class="order-summary-header">
                <h3><i class="fas fa-receipt"></i> Order Summary</h3>
                <span class="item-count"><%= cart.length %> item<%= cart.length !== 1 ? 's' : '' %></span>
              </div>
              
              <div class="order-summary-items">
                <% cart.forEach(item => { %>
                  <div class="summary-item">
                    <div class="summary-item-image">
                      <img src="<%= item.image %>" alt="<%= item.name %>">
                      <span class="summary-item-qty"><%= item.quantity %></span>
                    </div>
                    <div class="summary-item-info">
                      <span class="summary-item-name"><%= item.name %></span>
                      <span class="summary-item-price">₦<%= item.subtotal.toFixed(2) %></span>
                    </div>
                  </div>
                <% }) %>
              </div>
              
              <div class="order-summary-divider"></div>
              
              <div class="order-summary-details">
                <div class="summary-row">
                  <span>Subtotal</span>
                  <span>₦<%= totals.subtotal.toFixed(2) %></span>
                </div>
                <div class="summary-row">
                  <span>Shipping</span>
                  <span id="shippingCost"><%= totals.shippingLabel %></span>
                </div>
                <div class="summary-row">
                  <span>Tax</span>
                  <span>₦<%= totals.tax.toFixed(2) %></span>
                </div>
                <% if (totals.savings > 0) { %>
                  <div class="summary-row savings">
                    <span>Discount</span>
                    <span>-₦<%= totals.savings.toFixed(2) %></span>
                  </div>
                <% } %>
              </div>
              
              <div class="order-summary-divider"></div>
              
              <div class="order-summary-total">
                <span>Total</span>
                <span class="total-amount" id="orderTotal">₦<%= totals.total.toFixed(2) %></span>
              </div>
              
              <button type="submit" class="place-order-btn">
                <i class="fas fa-lock"></i> Place Order
              </button>
              
              <div class="secure-checkout">
                <div class="secure-item">
                  <i class="fas fa-shield-alt"></i>
                  <span>256-bit SSL Encryption</span>
                </div>
                <div class="secure-item">
                  <i class="fas fa-undo"></i>
                  <span>30-Day Money Back Guarantee</span>
                </div>
                <div class="secure-item">
                  <i class="fas fa-headset"></i>
                  <span>24/7 Customer Support</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </form>
    </div>
  </section>
</main>

<script>
var isNewAddress = <%= !addresses || addresses.length === 0 ? 'true' : 'false' %>;

function toggleNewAddress() {
  var form = document.getElementById('newAddressForm');
  var btn = document.getElementById('toggleAddressBtn');
  
  if (form.style.display === 'none') {
    form.style.display = 'block';
    btn.innerHTML = '<i class="fas fa-times-circle"></i> Use Saved Address';
    isNewAddress = true;
    document.querySelectorAll('input[name="shippingAddressId"]').forEach(function(input) {
      input.checked = false;
    });
    document.querySelectorAll('.saved-address').forEach(function(card) {
      card.classList.remove('selected');
    });
  } else {
    form.style.display = 'none';
    btn.innerHTML = '<i class="fas fa-plus-circle"></i> Add New Address';
    isNewAddress = false;
    var firstRadio = document.querySelector('input[name="shippingAddressId"]');
    if (firstRadio) {
      firstRadio.checked = true;
      firstRadio.closest('.saved-address').classList.add('selected');
    }
  }
}

// Shipping method selection
document.querySelectorAll('input[name="shippingMethod"]').forEach(function(input) {
  input.addEventListener('change', function() {
    document.querySelectorAll('.shipping-option').forEach(function(option) {
      option.classList.remove('selected');
    });
    this.closest('.shipping-option').classList.add('selected');
  });
});

// Payment method selection
document.querySelectorAll('input[name="paymentMethod"]').forEach(function(input) {
  input.addEventListener('change', function() {
    document.querySelectorAll('.payment-method').forEach(function(method) {
      method.classList.remove('selected');
    });
    this.closest('.payment-method').classList.add('selected');
  });
});

// Address card selection
document.querySelectorAll('.saved-address').forEach(function(card) {
  card.addEventListener('click', function() {
    document.querySelectorAll('.saved-address').forEach(function(c) { c.classList.remove('selected'); });
    this.classList.add('selected');
    document.getElementById('newAddressForm').style.display = 'none';
    document.getElementById('toggleAddressBtn').innerHTML = '<i class="fas fa-plus-circle"></i> Add New Address';
    isNewAddress = false;
  });
});

// Form submission
document.getElementById('checkoutForm').addEventListener('submit', function(e) {
  var hasSavedAddresses = document.getElementById('savedAddresses') !== null;
  
  if (hasSavedAddresses && !isNewAddress) {
    var selectedAddr = document.querySelector('input[name="shippingAddressId"]:checked');
    if (!selectedAddr) {
      e.preventDefault();
      alert('Please select a shipping address');
      return false;
    }
  } else {
    var fields = ['fullName', 'phone', 'street', 'city', 'state', 'zipCode'];
    for (var i = 0; i < fields.length; i++) {
      var field = document.getElementById(fields[i]);
      if (field && !field.value.trim()) {
        e.preventDefault();
        alert('Please fill in all shipping address fields');
        field.focus();
        return false;
      }
    }
  }
  
  return true;
});
</script>

<%- include('../partials/footer') %>
