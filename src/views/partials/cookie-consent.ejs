  justify-content: center;
}

.cookie-consent-icon i {
  font-size: 28px;
  color: #ff6a00;
}

.cookie-consent-text {
  flex: 1;
}

.cookie-consent-text h3 {
  margin: 0 0 8px;
  color: #fff;
  font-size: 18px;
}

.cookie-consent-text p {
