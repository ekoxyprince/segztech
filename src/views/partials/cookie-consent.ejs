      <div class="cookie-benefits">
        <h4><i class="fas fa-gift"></i> Benefits of Accepting</h4>
        <ul>
          <li><i class="fas fa-check"></i> Better product recommendations</li>
          <li><i class="fas fa-check"></i> Improved search suggestions</li>
          <li><i class="fas fa-check"></i> Region-based deals and offers</li>
          <li><i class="fas fa-check"></i> Personalized shopping experience</li>
        </ul>
