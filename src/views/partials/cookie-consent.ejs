          </div>
          <div class="data-item">
            <i class="fas fa-eye"></i>
            <span>Products Viewed</span>
          </div>
          <div class="data-item">
            <i class="fas fa-globe"></i>
            <span>Location Data</span>
          </div>
          <div class="data-item">
