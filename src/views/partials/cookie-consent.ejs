            <h4>Analytics Cookies</h4>
            <p>Help us understand how visitors interact with our website by collecting and reporting information anonymously. This helps us improve our site.</p>
          </div>
          <div class="cookie-toggle">
            <input type="checkbox" id="cookieAnalytics">
            <label for="cookieAnalytics"></label>
          </div>
        </div>
