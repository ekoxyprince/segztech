<!-- Product Card Component -->
<div class="product-card" data-product-id="<%= product.id %>">
  <!-- Wishlist Button - Top Left -->
  <button class="wishlist-btn <%= isInWishlist ? 'active' : '' %>" data-product-id="<%= product.id %>">
    <i class="<%= isInWishlist ? 'fas' : 'far' %> fa-heart"></i>
  </button>
  
  <!-- Badges - Top Right -->
  <div class="product-badges">
    <% if (product.is_flash_sale) { %>
      <span class="badge badge-flash"><i class="fas fa-bolt"></i> Flash</span>
    <% } %>
    <% if (product.discount > 0) { %>
      <span class="badge badge-discount">-<%= product.discount %>%</span>
    <% } %>
    <% if (product.is_featured) { %>
      <span class="badge badge-new">Featured</span>
    <% } %>
  </div>
  
  <!-- Product Image -->
  <a href="/products/<%= product.slug %>" class="product-image">
    <% const primaryImage = product.images && product.images.find(img => img.is_primary) || (product.images && product.images[0]); %>
    <% const fallbackImage = primaryImage ? primaryImage.image_url : '/images/placeholder.jpg'; %>
    <img src="<%= fallbackImage %>" alt="<%= product.name %>" loading="lazy">
    <% if (product.images && product.images.length > 1) { %>
      <% const hoverImage = product.images.find(img => !img.is_primary) || product.images[1]; %>
      <img src="<%= hoverImage.image_url %>" alt="<%= product.name %>" class="hover-image" loading="lazy">
    <% } %>
  </a>
  
  <!-- Product Info -->
  <div class="product-info">
    <span class="product-brand"><%= product.brand %></span>
    <a href="/products/<%= product.slug %>" class="product-name">
      <h3><%= product.name %></h3>
    </a>
    
    <!-- Rating -->
    <div class="product-rating">
      <div class="stars">
        <% for (let i = 1; i <= 5; i++) { %>
          <% if (i <= Math.floor(product.ratings)) { %>
            <i class="fas fa-star"></i>
          <% } else if (i - 0.5 <= product.ratings) { %>
            <i class="fas fa-star-half-alt"></i>
          <% } else { %>
            <i class="far fa-star"></i>
          <% } %>
        <% } %>
      </div>
      <span class="rating-count">(<%= product.review_count || 0 %>)</span>
    </div>
    
    <!-- Price -->
    <div class="product-price">
      <span class="current-price">₦<%= product.price.toFixed(2) %></span>
      <% if (product.original_price > product.price) { %>
        <span class="original-price">₦<%= product.original_price.toFixed(2) %></span>
      <% } %>
    </div>
    
    <!-- Add to Cart -->
    <button class="add-to-cart-btn" data-product-id="<%= product.id %>">
      <i class="fas fa-shopping-cart"></i>
      <span>Add to Cart</span>
    </button>
  </div>
</div>
